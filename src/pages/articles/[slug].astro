---
import Base from '../../layouts/Base.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { articles } from '../../data/articles';
import { SITE } from '../../config';
import { getHeadingsForArticle, getInfographicsForArticle } from '../../lib/infographics';

export function getStaticPaths() {
  return articles.map((article) => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

const { article } = Astro.props;

// Related articles: same category, excluding current
const related = articles
  .filter((a) => a.category === article.category && a.slug !== article.slug)
  .slice(0, 3);

// Dynamic content loading
const contentModules = import.meta.glob('../../content/articles/*.astro', { eager: true });
const contentKey = `../../content/articles/${article.slug}.astro`;
const ContentComponent = (contentModules[contentKey] as any)?.default ?? null;
const infographicShareLinks = Object.fromEntries(
  getInfographicsForArticle(article.slug).map((graphic) => [graphic.imageSrc, graphic.sharePath]),
);
const articleHeadings = getHeadingsForArticle(article.slug);
const authorSocials = {
  twitter: 'https://x.com/Jobizi',
  linkedin: 'https://www.linkedin.com/feed/',
};
---

<Base
  title={`${article.title} | Tupate Studio`}
  description={article.description}
>
  <Navbar />

  <!-- Article hero -->
  <section class="article-hero">
    <div class="container">
      <a href="/articles" class="back-link">&larr; All articles</a>
      <span class="article-hero-cat">{article.category}</span>
      <h1 class="article-hero-title">{article.title}</h1>
      <p class="article-hero-desc">{article.description}</p>
    </div>
  </section>

  <!-- Article body -->
  <section class="article-body">
    <div class="container">
      {ContentComponent ? (
        <div class="article-layout">
          <aside class="article-toc" aria-label="Table of contents">
            <div class="article-toc-card">
              <div class="article-toc-header">
                <span class="article-toc-icon" aria-hidden="true">
                  <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
                    <path d="M3.5 5h2.5" />
                    <path d="M8.5 5h8" />
                    <path d="M3.5 10h2.5" />
                    <path d="M8.5 10h8" />
                    <path d="M3.5 15h2.5" />
                    <path d="M8.5 15h8" />
                  </svg>
                </span>
                <p class="article-toc-label">Contents</p>
              </div>
              <nav class="article-toc-nav" id="article-toc">
                {articleHeadings.map((heading) => (
                  <a
                    href={`#${heading.id}`}
                    class:list={[
                      'toc-link',
                      heading.level === 'h3' && 'toc-link-sub',
                    ]}
                  >
                    {heading.text}
                  </a>
                ))}
              </nav>
            </div>
          </aside>

          <div class="article-content">
            <div class="article-prose" id="article-prose">
              <ContentComponent />
            </div>
          </div>

          <aside class="article-author" aria-label="Author information">
            <div class="article-author-card">
              <div class="article-author-avatar-wrap">
                <img
                  src="/job mugachia.png"
                  alt="Job Mugachia"
                  class="article-author-avatar"
                  loading="lazy"
                />
              </div>
              <h2 class="article-author-name">Job Mugachia</h2>
              <p class="article-author-role">Co-Founder</p>
              <p class="article-author-bio">
                Web strategist and founder of Tupate Studio. Job helps Kenyan businesses turn their websites into practical growth tools through clear strategy, strong positioning, and conversion-focused execution.
              </p>
              <div class="article-author-social">
                <a href={authorSocials.twitter} target="_blank" rel="noopener" aria-label="Twitter/X">
                    <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.737-8.835L1.254 2.25H8.08l4.253 5.622L18.244 2.25zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z"/></svg>
                </a>
                <a href={authorSocials.linkedin} target="_blank" rel="noopener" aria-label="LinkedIn">
                    <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                </a>
              </div>
            </div>
          </aside>
        </div>
      ) : (
        <div class="article-content">
          <div class="coming-soon-box">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="40" height="40">
              <circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>
            </svg>
            <h2>This guide is coming soon.</h2>
            <p>
              We're writing a full, practical guide on <strong>{article.title}</strong>. In the meantime, speak to our team directly, we're happy to answer any questions.
            </p>
            <a
              href={`https://wa.me/${SITE.whatsapp}?text=${encodeURIComponent(`Hi Tupate Studio, I have a question about: ${article.title}`)}`}
              class="cs-cta"
              target="_blank"
              rel="noopener"
            >
              Ask us on WhatsApp &rarr;
            </a>
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- Related articles -->
  {related.length > 0 && (
    <section class="related-section">
      <div class="container">
        <h2 class="related-heading">More in {article.category}</h2>
        <div class="related-grid">
          {related.map((a) => (
            <a href={`/articles/${a.slug}`} class="related-card">
              <span class="related-cat">{a.category}</span>
              <h3 class="related-title">{a.title}</h3>
              <p class="related-desc">{a.description}</p>
              <span class="related-read">Read article &rarr;</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <Footer />
</Base>

<script>
  const articleHeadings = JSON.parse(document.getElementById('article-headings')?.textContent ?? '[]');
  const infographicShareLinks = JSON.parse(document.getElementById('infographic-share-links')?.textContent ?? '{}');
  const prose = document.getElementById('article-prose');
  const toc = document.getElementById('article-toc');

  const initArticlePage = () => {
    if (prose && toc) {
      const renderedHeadings = Array.from(prose.querySelectorAll('h2, h3'));
      const tocLinks = Array.from(toc.querySelectorAll('.toc-link'));

      renderedHeadings.forEach((heading, index) => {
        const headingData = articleHeadings[index];
        if (headingData && !heading.id) {
          heading.id = headingData.id;
        }
      });

      if (tocLinks.length === 0 || renderedHeadings.length === 0) {
        toc.closest('.article-toc')?.setAttribute('hidden', 'hidden');
      } else {
        tocLinks.forEach((link) => {
          link.addEventListener('click', (event) => {
            const href = link.getAttribute('href');
            if (!href?.startsWith('#')) return;

            const target = prose.querySelector(href);
            if (!target) return;

            event.preventDefault();
            target.scrollIntoView({ behavior: 'smooth', block: 'start' });
            window.history.replaceState(null, '', href);
          });
        });

        const setActive = () => {
          let currentId = renderedHeadings[0]?.id;

          for (const heading of renderedHeadings) {
            if (heading.getBoundingClientRect().top <= 140) {
              currentId = heading.id;
            }
          }

          tocLinks.forEach((link) => {
            const href = link.getAttribute('href');
            link.classList.toggle('active', href === `#${currentId}`);
          });
        };

        setActive();
        document.addEventListener('scroll', setActive, { passive: true });
        window.addEventListener('resize', setActive);
      }
    }

    if (prose) {
      const figures = Array.from(prose.querySelectorAll('figure'));

      figures.forEach((figure) => {
        const image = figure.querySelector('img');
        if (!image) return;

        const sharePath = infographicShareLinks[image.getAttribute('src') ?? ''];
        if (!sharePath) return;

        if (image.parentElement?.tagName !== 'A') {
          const imageLink = document.createElement('a');
          imageLink.href = sharePath;
          imageLink.className = 'infographic-link';
          imageLink.setAttribute('aria-label', `Open share page for ${image.getAttribute('alt') ?? 'infographic'}`);
          image.parentNode?.insertBefore(imageLink, image);
          imageLink.appendChild(image);
        }

        if (!figure.querySelector('.infographic-actions')) {
          const actions = document.createElement('div');
          actions.className = 'infographic-actions';

          const shareButton = document.createElement('button');
          shareButton.type = 'button';
          shareButton.className = 'infographic-share-link';
          shareButton.textContent = 'Share this infographic';
          shareButton.dataset.shareUrl = new URL(sharePath, window.location.origin).toString();
          shareButton.dataset.shareTitle = image.getAttribute('alt') ?? 'Infographic';

          const backNote = document.createElement('span');
          backNote.className = 'infographic-share-note';
          backNote.textContent = 'Shared links include a backlink to this guide.';

          actions.appendChild(shareButton);
          actions.appendChild(backNote);
          figure.appendChild(actions);
        }
      });

      const shareButtons = Array.from(prose.querySelectorAll('.infographic-share-link'));
      shareButtons.forEach((button) => {
        button.addEventListener('click', async () => {
          const shareUrl = button.dataset.shareUrl;
          const shareTitle = button.dataset.shareTitle ?? 'Infographic';
          if (!shareUrl) return;

          try {
            if (navigator.share) {
              await navigator.share({
                title: shareTitle,
                text: `${shareTitle} from Tupate Studio`,
                url: shareUrl,
              });
              return;
            }

            if (navigator.clipboard?.writeText) {
              await navigator.clipboard.writeText(shareUrl);
              const originalText = button.textContent;
              button.textContent = 'Share link copied';
              window.setTimeout(() => {
                button.textContent = originalText;
              }, 1800);
              return;
            }

            window.open(shareUrl, '_blank', 'noopener');
          } catch {
            window.open(shareUrl, '_blank', 'noopener');
          }
        });
      });
    }
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initArticlePage, { once: true });
  } else {
    initArticlePage();
  }
</script>

<script type="application/json" id="article-headings">
  {JSON.stringify(articleHeadings)}
</script>

<script type="application/json" id="infographic-share-links">
  {JSON.stringify(infographicShareLinks)}
</script>

<style>
  /* ── Hero ── */
  .article-hero {
    background: #2563eb;
    padding: 72px 0 64px;
  }

  .back-link {
    display: inline-block;
    font-size: 13px;
    font-weight: 600;
    color: rgba(255,255,255,0.65);
    text-decoration: none;
    margin-bottom: 24px;
    transition: color 0.15s;
  }

  .back-link:hover {
    color: #ffffff;
  }

  .article-hero-cat {
    display: inline-block;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #93b4ff;
    margin-bottom: 14px;
  }

  .article-hero-title {
    font-family: var(--font-display);
    font-size: clamp(26px, 4vw, 44px);
    font-weight: 800;
    color: #ffffff;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 16px;
    max-width: 700px;
  }

  .article-hero-desc {
    font-size: 17px;
    color: rgba(255,255,255,0.75);
    line-height: 1.65;
    max-width: 560px;
  }

  /* ── Body ── */
  .article-body {
    background: #ffffff;
    padding: 80px 0;
  }

  .article-body .container {
    max-width: 1420px;
  }

  .article-layout {
    display: grid;
    grid-template-columns: 280px minmax(0, 760px) 280px;
    gap: 56px;
    align-items: start;
    justify-content: center;
  }

  .article-toc {
    position: sticky;
    top: 108px;
    align-self: start;
  }

  .article-toc-card {
    padding: 22px 18px 18px;
    border: 1px solid #dfe7f5;
    border-radius: 18px;
    background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
    box-shadow: 0 18px 44px rgba(148, 163, 184, 0.14);
  }

  .article-toc-header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 12px;
  }

  .article-toc-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    color: #111827;
  }

  .article-toc-label {
    font-size: 14px;
    font-weight: 800;
    letter-spacing: -0.01em;
    color: #111827;
  }

  .article-toc-nav {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .article-toc-nav :global(.toc-link) {
    display: block;
    position: relative;
    padding: 7px 10px;
    border-radius: 10px;
    font-size: 12px;
    font-weight: 600;
    line-height: 1.4;
    color: #5b6b84;
    text-decoration: none;
    transition: background 0.18s ease, color 0.18s ease, transform 0.18s ease;
  }

  .article-toc-nav :global(.toc-link:hover) {
    background: #f2f6ff;
    color: #315fdd;
  }

  .article-toc-nav :global(.toc-link.active) {
    background: #e9f0ff;
    color: #4b74ec;
  }

  .article-toc-nav :global(.toc-link.active::before) {
    content: '';
    position: absolute;
    left: 0;
    top: 7px;
    bottom: 7px;
    width: 4px;
    border-radius: 999px;
    background: #4b74ec;
  }

  .article-toc-nav :global(.toc-link-sub) {
    padding-left: 20px;
    font-size: 11px;
    font-weight: 500;
  }

  .article-content {
    max-width: 760px;
    min-width: 0;
  }

  .article-author {
    position: sticky;
    top: 108px;
    align-self: start;
  }

  .article-author-card {
    padding: 26px 22px 20px;
    border: 1px solid #dfe7f5;
    border-radius: 18px;
    background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
    box-shadow: 0 18px 44px rgba(148, 163, 184, 0.14);
    text-align: center;
  }

  .article-author-avatar-wrap {
    width: 108px;
    height: 108px;
    margin: 0 auto 18px;
    padding: 6px;
    border-radius: 999px;
    background: linear-gradient(180deg, #6ea5ff 0%, #3b82f6 100%);
    box-shadow: 0 10px 26px rgba(59, 130, 246, 0.22);
  }

  .article-author-avatar {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 999px;
    display: block;
    background: #ffffff;
  }

  .article-author-name {
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 800;
    color: #111827;
    line-height: 1.25;
    margin-bottom: 4px;
  }

  .article-author-role {
    font-size: 13px;
    color: #5f6f86;
    margin-bottom: 18px;
  }

  .article-author-bio {
    font-family: var(--font-reading);
    font-size: 14px;
    line-height: 1.75;
    color: #5b6b84;
    margin-bottom: 18px;
  }

  .article-author-social {
    display: flex;
    justify-content: center;
    gap: 10px;
  }

  .article-author-social a {
    width: 40px;
    height: 40px;
    border-radius: 999px;
    border: 1px solid #d8e1f1;
    background: #ffffff;
    color: #66768d;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    transition: border-color 0.18s ease, color 0.18s ease, transform 0.18s ease;
  }

  .article-author-social a:hover {
    border-color: #9db8f5;
    color: #315fdd;
    transform: translateY(-1px);
  }

  .coming-soon-box {
    background: #f7f8fc;
    border: 1px solid #e8ecf4;
    border-radius: 16px;
    padding: 48px 40px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 16px;
    color: #888888;
  }

  .coming-soon-box h2 {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 800;
    color: #111111;
  }

  .coming-soon-box p {
    font-size: 15px;
    color: #666666;
    line-height: 1.65;
    max-width: 480px;
  }

  .cs-cta {
    display: inline-flex;
    align-items: center;
    background: #2563eb;
    color: #ffffff;
    font-size: 15px;
    font-weight: 700;
    padding: 13px 26px;
    border-radius: 8px;
    text-decoration: none;
    margin-top: 8px;
    transition: background 0.18s ease;
  }

  .cs-cta:hover {
    background: #1d4ed8;
  }

  /* ── Related ── */
  .related-section {
    background: #f7f8fc;
    padding: 64px 0 80px;
    border-top: 1px solid #e8ecf4;
  }

  .related-heading {
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #2563eb;
    border-bottom: 2px solid #e8ecf4;
    padding-bottom: 12px;
    margin-bottom: 28px;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .related-card {
    background: #ffffff;
    border: 1px solid #e8ecf4;
    border-radius: 14px;
    padding: 24px;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .related-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 32px rgba(37, 99, 235, 0.10);
  }

  .related-cat {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #2563eb;
    margin-bottom: 8px;
  }

  .related-title {
    font-family: var(--font-display);
    font-size: 15px;
    font-weight: 700;
    color: #111111;
    line-height: 1.35;
    margin-bottom: 8px;
  }

  .related-desc {
    font-size: 13px;
    color: #777777;
    line-height: 1.6;
    flex: 1;
    margin-bottom: 16px;
  }

  .related-read {
    font-size: 13px;
    font-weight: 700;
    color: #2563eb;
  }

  /* ── Prose ── */
  .article-prose h2 {
    font-family: var(--font-display);
    font-size: 26px;
    font-weight: 800;
    color: #111111;
    line-height: 1.24;
    letter-spacing: -0.01em;
    margin: 56px 0 18px;
    scroll-margin-top: 120px;
  }

  .article-prose h3 {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 700;
    color: #111111;
    line-height: 1.3;
    margin: 36px 0 14px;
    scroll-margin-top: 120px;
  }

  .article-prose p {
    font-family: var(--font-reading);
    font-size: 18px;
    color: #445065;
    line-height: 1.8;
    letter-spacing: -0.01em;
    margin-bottom: 28px;
  }

  .article-prose ul,
  .article-prose ol {
    font-family: var(--font-reading);
    font-size: 17px;
    color: #445065;
    line-height: 1.8;
    margin: 0 0 28px 0;
    padding-left: 28px;
  }

  .article-prose li {
    margin-bottom: 12px;
  }

  .article-prose strong {
    font-weight: 700;
    color: #1f2937;
  }

  .article-prose a {
    color: #2563eb;
    text-decoration: underline;
    text-decoration-thickness: 1.5px;
    text-underline-offset: 0.16em;
  }

  .article-prose a:hover {
    color: #1d4ed8;
  }

  .article-prose blockquote {
    border-left: 4px solid #2563eb;
    padding: 20px 26px;
    margin: 36px 0;
    background: #f0f5ff;
    border-radius: 0 8px 8px 0;
    font-family: var(--font-reading);
    font-size: 18px;
    line-height: 1.8;
    font-style: italic;
    color: #445065;
  }

  .article-prose table {
    width: 100%;
    border-collapse: collapse;
    margin: 28px 0;
    font-size: 15px;
  }

  .article-prose th {
    background: #f7f8fc;
    font-weight: 700;
    color: #111111;
    padding: 12px 16px;
    text-align: left;
    border-bottom: 2px solid #e8ecf4;
  }

  .article-prose td {
    padding: 12px 16px;
    color: #444444;
    border-bottom: 1px solid #e8ecf4;
    vertical-align: top;
  }

  .article-prose tr:last-child td {
    border-bottom: none;
  }

  .article-prose .cta-box {
    background: #2563eb;
    border-radius: 16px;
    padding: 36px 40px;
    margin: 48px 0;
    color: #ffffff;
  }

  .article-prose .cta-box h3 {
    color: #ffffff;
    font-size: 20px;
    margin: 0 0 10px;
  }

  .article-prose .cta-box p {
    color: rgba(255,255,255,0.8);
    margin-bottom: 20px;
  }

  .article-prose .cta-box a {
    display: inline-flex;
    background: #ffffff;
    color: #2563eb;
    font-weight: 700;
    font-size: 15px;
    padding: 12px 24px;
    border-radius: 8px;
    text-decoration: none;
    transition: opacity 0.15s;
  }

  .article-prose .cta-box a:hover {
    opacity: 0.9;
    color: #2563eb;
  }

  .article-prose figure {
    margin: 40px 0;
    text-align: center;
  }

  .article-prose figure img,
  .article-prose figure svg {
    width: 100%;
    max-width: 680px;
    height: auto;
    border-radius: 12px;
    border: 1px solid #e8ecf4;
    background: #f7f8fc;
    display: block;
    margin: 0 auto;
  }

  .article-prose :global(.infographic-link) {
    display: block;
    text-decoration: none;
  }

  .article-prose :global(.infographic-actions) {
    display: flex;
