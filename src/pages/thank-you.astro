---
import Base from '../layouts/Base.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { SITE } from '../config';
import { buildWhatsAppUrl } from '../lib/offers';

const whatsappUrl = buildWhatsAppUrl(
  SITE.whatsapp,
  "Hi Tupate Studio, I've just submitted the quote form and wanted to follow up on WhatsApp.",
);
---

<Base
  title="Thank You | Tupate Studio"
  description="Thanks for requesting a quote from Tupate Studio."
>
  <Navbar />

  <section class="thanks-section">
    <div class="container thanks-shell">
      <span class="thanks-eyebrow">Thank You</span>
      <h1 class="thanks-title">Your quote request has been sent.</h1>
      <p class="thanks-sub" id="thanks-message">
        We have your details and will reply with the best next step for your project.
      </p>

      <div class="thanks-actions">
        <a href={whatsappUrl} class="thanks-btn thanks-btn-primary" target="_blank" rel="noopener" data-conversion="whatsapp">
          Continue on WhatsApp
        </a>
        <a href="/pricing" class="thanks-btn thanks-btn-secondary">
          Review pricing again
        </a>
      </div>

      <div class="thanks-card">
        <p class="thanks-card-title">What happens next?</p>
        <p class="thanks-card-copy">1. We review your request.</p>
        <p class="thanks-card-copy">2. We reply with the right package, timeline, and any add-ons if needed.</p>
        <p class="thanks-card-copy">3. If you want to move faster, WhatsApp is still the fastest channel.</p>
      </div>
    </div>
  </section>

  <Footer />
</Base>

<script is:inline>
  const params = new URLSearchParams(window.location.search);
  const service = params.get('service');
  const source = params.get('source') || 'website';
  const message = document.getElementById('thanks-message');
  const stored = window.sessionStorage.getItem('tupate_quote_submission');

  if (message && service) {
    message.textContent = `We have your ${service} request and will reply with the best next step for your project.`;
  }

  if (typeof window.gtag === 'function') {
    window.gtag('event', 'generate_lead', {
      event_category: 'Lead',
      event_label: service || 'Quote form',
      method: 'thank_you_page',
      form_location: source,
    });
  }

  if (stored) {
    window.sessionStorage.removeItem('tupate_quote_submission');
  }
</script>

<style>
  .thanks-section {
    background: #f7f8fc;
    padding: 140px 0 96px;
    min-height: calc(100vh - 72px);
  }

  .thanks-shell {
    max-width: 760px;
  }

  .thanks-eyebrow {
    display: inline-block;
    margin-bottom: 18px;
    padding: 6px 12px;
    border-radius: 999px;
    background: #e8efff;
    color: #2563eb;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .thanks-title {
    font-size: clamp(34px, 5vw, 56px);
    line-height: 1.05;
    margin-bottom: 16px;
  }

  .thanks-sub {
    font-size: 18px;
    line-height: 1.7;
    color: #5b6b84;
    max-width: 640px;
  }

  .thanks-actions {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    margin-top: 28px;
  }

  .thanks-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 50px;
    padding: 0 22px;
    border-radius: 10px;
    font-size: 15px;
    font-weight: 700;
    text-decoration: none;
  }

  .thanks-btn-primary {
    background: #2563eb;
    color: #ffffff;
  }

  .thanks-btn-secondary {
    border: 1px solid #cfd8ea;
    background: #ffffff;
    color: #111827;
  }

  .thanks-card {
    margin-top: 32px;
    padding: 24px;
    border-radius: 18px;
    background: #ffffff;
    border: 1px solid #dfe7f5;
    box-shadow: 0 18px 44px rgba(148, 163, 184, 0.14);
  }

  .thanks-card-title {
    font-size: 16px;
    font-weight: 700;
    color: #111827;
    margin-bottom: 12px;
  }

  .thanks-card-copy {
    font-size: 15px;
    line-height: 1.7;
    color: #445065;
  }

  @media (max-width: 640px) {
    .thanks-section {
      padding: 120px 0 72px;
    }

    .thanks-actions {
      flex-direction: column;
    }

    .thanks-btn {
      width: 100%;
    }
  }
</style>
