---
import Base from '../layouts/Base.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import QuoteForm from '../components/QuoteForm.astro';
import { SITE } from '../config';
import { addOns, buildWhatsAppUrl, offers } from '../lib/offers';

const quoteCta = buildWhatsAppUrl(
  SITE.whatsapp,
  "Hi Tupate Studio, I'd like help choosing the right package for my business.",
);
---

<Base
  title="Web Design Prices Kenya | Tupate Studio Pricing"
  description="See exactly what you pay for a website, SEO, maintenance, or Google Ads in Kenya. Flat prices, no surprises."
>
  <Navbar />

  <section class="pricing-hero">
    <div class="container">
      <span class="section-label">Pricing</span>
      <h1 class="pricing-h1">Simple pricing built to close faster</h1>
      <p class="pricing-sub">
        The same offer now runs across the homepage, pricing, and quote flow. Start with a website,
        add growth when you are ready, and keep WhatsApp as the fast lane.
      </p>
    </div>
  </section>

  <section class="cards-section">
    <div class="container">
      <div class="cards-grid">
        {offers.map((offer, index) => (
          <div class:list={['pricing-card', index === 0 && 'pricing-card--featured']}>
            {index === 0 && <div class="card-badge">Most popular</div>}
            <p class="card-name">{offer.name}</p>
            <div class="card-price-row">
              <span class="card-price">{offer.price}</span>
            </div>
            <p class="card-subtext">{offer.cadence}</p>
            <p class="card-summary">{offer.summary}</p>

            <ul class="card-features">
              {offer.features.map((feature) => (
                <li>
                  <span class="check" aria-hidden="true">✓</span>
                  {feature}
                </li>
              ))}
            </ul>

            <a
              href={buildWhatsAppUrl(
                SITE.whatsapp,
                `Hi Tupate Studio, I'm interested in the ${offer.whatsappLabel} package. Can I get a quote?`,
              )}
              class:list={['card-cta', index === 0 && 'card-cta--featured']}
              target="_blank"
              rel="noopener"
              data-conversion="whatsapp"
            >
              Discuss on WhatsApp
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <QuoteForm
    id="pricing-quote"
    source="pricing"
    title="Want us to recommend the right package?"
    subtitle="Use the short quote form if you want a reply by email first, then jump to WhatsApp when you are ready."
  />

  <section class="addons-section">
    <div class="container">
      <div class="addons-header">
        <h2 class="addons-heading">Optional add-ons</h2>
        <p class="addons-sub">Only pay for the extra scope you actually need.</p>
      </div>

      <div class="addons-grid">
        {addOns.map((addon) => (
          <div class="addon-row">
            <div class="addon-left">
              <p class="addon-name">{addon.name}</p>
              <p class="addon-desc">{addon.description}</p>
            </div>
            <span class="addon-price">
              {addon.price}
              <span class="addon-freq">{addon.cadence}</span>
            </span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="trust-section">
    <div class="container trust-grid">
      <div class="trust-item">
        <p class="trust-title">Same offer everywhere</p>
        <p class="trust-desc">No mismatch between the homepage, pricing page, and quote flow.</p>
      </div>
      <div class="trust-item">
        <p class="trust-title">Fast next step</p>
        <p class="trust-desc">Use the form if you want structure, or WhatsApp us if you want speed.</p>
      </div>
      <div class="trust-item">
        <p class="trust-title">Built for conversion</p>
        <p class="trust-desc">Website first, then SEO, maintenance, or ads when the base is ready.</p>
      </div>
    </div>
  </section>

  <section class="final-cta-section">
    <div class="container final-cta-inner">
      <h2 class="final-cta-heading">Need a quick answer instead?</h2>
      <p class="final-cta-sub">
        Send one WhatsApp message and we will tell you which package fits your business.
      </p>
      <a href={quoteCta} class="final-cta-btn" target="_blank" rel="noopener" data-conversion="whatsapp">
        Chat with us on WhatsApp
      </a>
    </div>
  </section>

  <Footer />
</Base>

<style>
  .pricing-hero {
    background-color: #0f172a;
    background-image: linear-gradient(135deg, #0f172a 0%, #1e2d5a 100%);
    padding: 140px 0 96px;
  }

  .pricing-h1 {
    font-size: clamp(32px, 5vw, 56px);
    color: #ffffff;
    line-height: 1.08;
    margin-bottom: 24px;
    max-width: 760px;
  }

  .pricing-sub {
    font-size: 17px;
    color: rgba(255, 255, 255, 0.72);
    line-height: 1.7;
    max-width: 620px;
  }

  .cards-section {
    background: #f7f8fc;
    padding: 80px 0 96px;
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    align-items: start;
  }

  .pricing-card {
    position: relative;
    background: #ffffff;
    border: 1px solid #e8ecf4;
    border-radius: 20px;
    padding: 36px 32px 32px;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .pricing-card--featured {
    border-color: #2563eb;
    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.12), 0 16px 48px rgba(37, 99, 235, 0.14);
  }

  .card-badge {
    position: absolute;
    top: -14px;
    left: 32px;
    background: #2563eb;
    color: #ffffff;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 5px 16px;
    border-radius: 999px;
  }

  .card-name {
    font-size: 18px;
    font-weight: 700;
    color: #111111;
    margin-bottom: 20px;
  }

  .card-price-row {
    margin-bottom: 6px;
  }

  .card-price {
    font-size: 40px;
    font-weight: 800;
    color: #111111;
    line-height: 1;
  }

  .pricing-card--featured .card-price {
    color: #2563eb;
  }

  .card-subtext {
    font-size: 13px;
    color: #7a869a;
    margin-bottom: 14px;
  }

  .card-summary {
    font-size: 14px;
    line-height: 1.6;
    color: #445065;
    margin-bottom: 22px;
  }

  .card-features {
    list-style: none;
    display: grid;
    gap: 13px;
    flex: 1;
    margin-bottom: 32px;
  }

  .card-features li {
    display: flex;
    gap: 10px;
    font-size: 14px;
    color: #444444;
    line-height: 1.5;
  }

  .check {
    color: #2563eb;
    font-weight: 700;
    flex-shrink: 0;
  }

  .card-cta {
    display: block;
    text-align: center;
    padding: 14px 24px;
    border-radius: 10px;
    font-size: 15px;
    font-weight: 700;
    text-decoration: none;
    background: #f0f4ff;
    color: #2563eb;
    border: 1.5px solid #c7d5fc;
  }

  .card-cta--featured {
    background: #2563eb;
    color: #ffffff;
    border-color: #2563eb;
  }

  .addons-section {
    background: #ffffff;
    padding: 80px 0 96px;
    border-top: 1px solid #e8ecf4;
  }

  .addons-header {
    margin-bottom: 40px;
  }

  .addons-heading {
    font-size: clamp(24px, 3vw, 36px);
    margin-bottom: 8px;
  }

  .addons-sub {
    font-size: 15px;
    color: #7a869a;
  }

  .addons-grid {
    display: flex;
    flex-direction: column;
    border: 1px solid #e8ecf4;
    border-radius: 16px;
    overflow: hidden;
  }

  .addon-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 24px 28px;
    border-bottom: 1px solid #e8ecf4;
  }

  .addon-row:last-child {
    border-bottom: none;
  }

  .addon-row:nth-child(odd) {
    background: #fafbff;
  }

  .addon-left {
    flex: 1;
  }

  .addon-name {
    font-size: 15px;
    font-weight: 700;
    color: #111111;
    margin-bottom: 4px;
  }

  .addon-desc {
    font-size: 13px;
    color: #7a869a;
    line-height: 1.5;
  }

  .addon-price {
    font-size: 17px;
    font-weight: 800;
    color: #2563eb;
    white-space: nowrap;
    text-align: right;
  }

  .addon-freq {
    display: block;
    margin-top: 2px;
    font-size: 12px;
    font-weight: 500;
    color: #7a869a;
  }

  .trust-section {
    background: #f7f8fc;
    padding: 56px 0;
    border-top: 1px solid #e8ecf4;
    border-bottom: 1px solid #e8ecf4;
  }

  .trust-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .trust-item {
    background: #ffffff;
    border: 1px solid #e8ecf4;
    border-radius: 16px;
    padding: 24px;
  }

  .trust-title {
    font-size: 15px;
    font-weight: 700;
    color: #111111;
    margin-bottom: 8px;
  }

  .trust-desc {
    font-size: 14px;
    color: #5b6b84;
    line-height: 1.6;
  }

  .final-cta-section {
    background: #ffffff;
    padding: 96px 0;
  }

  .final-cta-inner {
    text-align: center;
    max-width: 580px;
    margin: 0 auto;
  }

  .final-cta-heading {
    font-size: clamp(24px, 3.5vw, 36px);
    margin-bottom: 16px;
    line-height: 1.15;
  }

  .final-cta-sub {
    font-size: 16px;
    color: #666666;
    line-height: 1.65;
    margin-bottom: 36px;
  }

  .final-cta-btn {
    display: inline-flex;
    align-items: center;
    min-height: 50px;
    padding: 0 28px;
    border-radius: 10px;
    background: #2563eb;
    color: #ffffff;
    font-size: 16px;
    font-weight: 700;
    text-decoration: none;
  }

  @media (max-width: 960px) {
    .cards-grid,
    .trust-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .addon-row {
      flex-direction: column;
      align-items: flex-start;
    }

    .addon-price,
    .addon-freq {
      text-align: left;
    }
  }
</style>
