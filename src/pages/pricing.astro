---
import Base from '../layouts/Base.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import QuoteForm from '../components/QuoteForm.astro';
import { SITE } from '../config';
import { addOns, buildWhatsAppUrl, offers } from '../lib/offers';

const quoteCta = buildWhatsAppUrl(
  SITE.whatsapp,
  "Hi Tupate Studio, I'd like help choosing the right marketing pack for my business.",
);
---

<Base
  title="Marketing Pricing Kenya | Tupate Studio"
  description="Transparent monthly marketing pack prices for Kenyan businesses. Starter from Ksh 8,000/month. No lock-in contracts."
>
  <Navbar />

  <section class="pricing-hero">
    <div class="container">
      <span class="section-label">Pricing</span>
      <h1 class="pricing-h1">Straightforward pricing. No lock-in.</h1>
      <p class="pricing-sub">
        Pick the pack that fits where your business is right now. Cancel or upgrade any month.
        Add a website or one-off service whenever you need it.
      </p>
    </div>
  </section>

  <section class="cards-section">
    <div class="container">
      <div class="cards-grid">
        {offers.map((offer) => (
          <div class:list={['pricing-card', offer.featured && 'pricing-card--featured']}>
            {offer.featured && <div class="card-badge">Most Popular</div>}
            <p class="card-name">{offer.name}</p>
            <div class="card-price-row">
              <span class="card-price">{offer.price}</span>
            </div>
            <p class="card-subtext">{offer.cadence}</p>
            <p class="card-summary">{offer.summary}</p>

            <ul class="card-features">
              {offer.features.map((feature) => (
                <li>
                  <span class="check" aria-hidden="true">✓</span>
                  {feature}
                </li>
              ))}
            </ul>

            <a
              href={buildWhatsAppUrl(
                SITE.whatsapp,
                `Hi Tupate Studio, I'm interested in the ${offer.whatsappLabel}. Can I get started?`,
              )}
              class:list={['card-cta', offer.featured && 'card-cta--featured']}
              target="_blank"
              rel="noopener"
              data-conversion="whatsapp"
            >
              Get Started
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <QuoteForm
    id="pricing-quote"
    source="pricing"
    title="Not sure which pack fits?"
    subtitle="Tell us about your business and we will recommend the right starting point."
  />

  <section class="addons-section">
    <div class="container">
      <div class="addons-header">
        <h2 class="addons-heading">Website &amp; add-on services</h2>
        <p class="addons-sub">One-off and monthly add-ons you can bolt onto any pack.</p>
      </div>

      <div class="addons-grid">
        {addOns.map((addon) => (
          <div class="addon-row">
            <div class="addon-left">
              <p class="addon-name">{addon.name}</p>
              <p class="addon-desc">{addon.description}</p>
            </div>
            <span class="addon-price">
              {addon.price}
              <span class="addon-freq">{addon.cadence}</span>
            </span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="trust-section">
    <div class="container trust-grid">
      <div class="trust-item">
        <p class="trust-title">No lock-in contracts</p>
        <p class="trust-desc">Cancel or change your pack any month. We earn your business every month.</p>
      </div>
      <div class="trust-item">
        <p class="trust-title">Monthly reports included</p>
        <p class="trust-desc">Every pack includes a plain-English performance report so you always know what is working.</p>
      </div>
      <div class="trust-item">
        <p class="trust-title">Website is optional</p>
        <p class="trust-desc">Start marketing immediately. Add a website build or redesign whenever you are ready.</p>
      </div>
    </div>
  </section>

  <section class="final-cta-section">
    <div class="container final-cta-inner">
      <h2 class="final-cta-heading">Want a quick recommendation?</h2>
      <p class="final-cta-sub">
        Send one WhatsApp message and we will tell you which pack fits your business right now.
      </p>
      <a href={quoteCta} class="final-cta-btn" target="_blank" rel="noopener" data-conversion="whatsapp">
        Chat with us on WhatsApp
      </a>
    </div>
  </section>

  <Footer />
</Base>

<style>
  .pricing-hero {
    background-color: #0E1F3D;
    background-image: linear-gradient(135deg, #0E1F3D 0%, #1B4FD8 100%);
    padding: 140px 0 96px;
  }

  .section-label {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #F25C2A;
    margin-bottom: 16px;
  }

  .pricing-h1 {
    font-size: clamp(32px, 5vw, 56px);
    color: #ffffff;
    line-height: 1.08;
    margin-bottom: 24px;
    max-width: 760px;
  }

  .pricing-sub {
    font-size: 17px;
    color: rgba(255, 255, 255, 0.72);
    line-height: 1.7;
    max-width: 620px;
  }

  .cards-section {
    background: #F4F7FF;
    padding: 80px 0 96px;
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    align-items: start;
  }

  .pricing-card {
    position: relative;
    background: #ffffff;
    border: 1.5px solid #E2E8F6;
    border-radius: 20px;
    padding: 36px 30px 32px;
    display: flex;
    flex-direction: column;
  }

  .pricing-card--featured {
    background: #0E1F3D;
    border-color: #0E1F3D;
    transform: translateY(-10px);
    box-shadow: 0 24px 56px rgba(14, 31, 61, 0.25);
  }

  .card-badge {
    position: absolute;
    top: -13px;
    left: 50%;
    transform: translateX(-50%);
    background: #F25C2A;
    color: #fff;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 4px 14px;
    border-radius: 20px;
    white-space: nowrap;
  }

  .card-name {
    font-size: 18px;
    font-weight: 700;
    color: #0E1F3D;
    margin-bottom: 16px;
  }

  .pricing-card--featured .card-name {
    color: #ffffff;
  }

  .card-price-row {
    margin-bottom: 4px;
  }

  .card-price {
    font-size: 36px;
    font-weight: 800;
    color: #1B4FD8;
    line-height: 1;
  }

  .pricing-card--featured .card-price {
    color: #ffffff;
  }

  .card-subtext {
    font-size: 12px;
    color: #6B7A99;
    margin-bottom: 14px;
  }

  .pricing-card--featured .card-subtext {
    color: rgba(255, 255, 255, 0.45);
  }

  .card-summary {
    font-size: 13px;
    line-height: 1.6;
    color: #6B7A99;
    margin-bottom: 20px;
    padding-bottom: 20px;
    border-bottom: 1px solid #E2E8F6;
  }

  .pricing-card--featured .card-summary {
    color: rgba(255, 255, 255, 0.55);
    border-bottom-color: rgba(255, 255, 255, 0.12);
  }

  .card-features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 11px;
    flex: 1;
    margin-bottom: 28px;
    padding: 0;
  }

  .card-features li {
    display: flex;
    gap: 10px;
    font-size: 13.5px;
    color: #1A1A2E;
    line-height: 1.5;
  }

  .pricing-card--featured .card-features li {
    color: rgba(255, 255, 255, 0.82);
  }

  .check {
    font-size: 12px;
    font-weight: 700;
    color: #1B4FD8;
    background: #EEF3FF;
    border-radius: 50%;
    min-width: 20px;
    height: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 1px;
  }

  .pricing-card--featured .check {
    background: rgba(255, 255, 255, 0.15);
    color: #ffffff;
  }

  .card-cta {
    display: block;
    text-align: center;
    padding: 13px;
    border-radius: 10px;
    font-size: 14px;
    font-weight: 500;
    text-decoration: none;
    background: transparent;
    color: #0E1F3D;
    border: 1.5px solid #E2E8F6;
    transition: all 0.2s ease;
  }

  .card-cta:hover {
    border-color: #1B4FD8;
    color: #1B4FD8;
  }

  .card-cta--featured {
    background: #F25C2A;
    color: #ffffff;
    border-color: transparent;
  }

  .card-cta--featured:hover {
    background: #d94d20;
    color: #ffffff;
  }

  /* Add-ons */
  .addons-section {
    background: #ffffff;
    padding: 80px 0 96px;
    border-top: 1px solid #E2E8F6;
  }

  .addons-header {
    margin-bottom: 40px;
  }

  .addons-heading {
    font-size: clamp(24px, 3vw, 36px);
    margin-bottom: 8px;
  }

  .addons-sub {
    font-size: 15px;
    color: #6B7A99;
  }

  .addons-grid {
    display: flex;
    flex-direction: column;
    border: 1px solid #E2E8F6;
    border-radius: 16px;
    overflow: hidden;
  }

  .addon-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 24px 28px;
    border-bottom: 1px solid #E2E8F6;
  }

  .addon-row:last-child {
    border-bottom: none;
  }

  .addon-row:nth-child(odd) {
    background: #fafbff;
  }

  .addon-left {
    flex: 1;
  }

  .addon-name {
    font-size: 15px;
    font-weight: 700;
    color: #0E1F3D;
    margin-bottom: 4px;
  }

  .addon-desc {
    font-size: 13px;
    color: #6B7A99;
    line-height: 1.5;
  }

  .addon-price {
    font-size: 17px;
    font-weight: 800;
    color: #1B4FD8;
    white-space: nowrap;
    text-align: right;
  }

  .addon-freq {
    display: block;
    margin-top: 2px;
    font-size: 12px;
    font-weight: 500;
    color: #6B7A99;
  }

  /* Trust */
  .trust-section {
    background: #F4F7FF;
    padding: 56px 0;
    border-top: 1px solid #E2E8F6;
    border-bottom: 1px solid #E2E8F6;
  }

  .trust-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .trust-item {
    background: #ffffff;
    border: 1px solid #E2E8F6;
    border-radius: 16px;
    padding: 24px;
  }

  .trust-title {
    font-size: 15px;
    font-weight: 700;
    color: #0E1F3D;
    margin-bottom: 8px;
  }

  .trust-desc {
    font-size: 14px;
    color: #6B7A99;
    line-height: 1.6;
  }

  /* Final CTA */
  .final-cta-section {
    background: #ffffff;
    padding: 96px 0;
  }

  .final-cta-inner {
    text-align: center;
    max-width: 580px;
    margin: 0 auto;
  }

  .final-cta-heading {
    font-size: clamp(24px, 3.5vw, 36px);
    margin-bottom: 16px;
    line-height: 1.15;
  }

  .final-cta-sub {
    font-size: 16px;
    color: #6B7A99;
    line-height: 1.65;
    margin-bottom: 36px;
  }

  .final-cta-btn {
    display: inline-flex;
    align-items: center;
    min-height: 50px;
    padding: 0 28px;
    border-radius: 10px;
    background: #1B4FD8;
    color: #ffffff;
    font-size: 16px;
    font-weight: 700;
    text-decoration: none;
    transition: background 0.2s ease;
  }

  .final-cta-btn:hover {
    background: #1540b8;
  }

  /* Responsive */
  @media (max-width: 960px) {
    .cards-grid,
    .trust-grid {
      grid-template-columns: 1fr;
    }

    .pricing-card--featured {
      transform: none;
    }
  }

  @media (max-width: 640px) {
    .addon-row {
      flex-direction: column;
      align-items: flex-start;
    }

    .addon-price,
    .addon-freq {
      text-align: left;
    }
  }
</style>
