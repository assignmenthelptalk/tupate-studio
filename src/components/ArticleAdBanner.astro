---
// Banner B – 300×250 Medium Rectangle
// Placed in the article right sidebar below the author card
---

<div class="ad-banner">

  <div class="ab-head">
    <div class="ab-logomark">T</div>
    <span class="ab-brandname">Tupate Studio</span>
    <div class="ab-tagline-r">SEO &amp; Web Design<br>Kenya</div>
  </div>

  <div class="ab-body">
    <div class="ab-text">
      <div class="ab-eyebrow">Rank #1 on Google</div>
      <div class="ab-headline">Your customers<br>are <em>searching</em><br>for you now</div>
      <div class="ab-subtext">We make sure they<br>find <em class="ab-em-white">you</em> first</div>
    </div>

    <div class="ab-visual">
      <svg width="88" height="118" viewBox="0 0 95 130" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect x="8" y="4" width="79" height="122" rx="11" fill="#1e293b" stroke="#334155" stroke-width="1.5"/>
        <rect x="13" y="13" width="69" height="104" rx="6" fill="#0f172a"/>
        <circle cx="29" cy="22" r="2.8" fill="#4285F4"/>
        <circle cx="36" cy="22" r="2.8" fill="#EA4335"/>
        <circle cx="43" cy="22" r="2.8" fill="#FBBC05"/>
        <circle cx="50" cy="22" r="2.8" fill="#34A853"/>
        <rect x="16" y="28" width="63" height="9" rx="4.5" fill="#1e293b" stroke="#3b5bdb" stroke-width="1"/>
        <circle cx="72" cy="32.5" r="3" fill="none" stroke="#60a5fa" stroke-width="1.2"/>
        <line x1="74" y1="35" x2="76.5" y2="37.5" stroke="#60a5fa" stroke-width="1.2" stroke-linecap="round"/>
        <rect x="16" y="42" width="63" height="26" rx="4" fill="#1e3a5f" stroke="#2563eb" stroke-width="1.5"/>
        <rect x="19" y="45" width="18" height="4" rx="2" fill="#60a5fa" opacity=".7"/>
        <rect x="19" y="52" width="57" height="2.5" rx="1.5" fill="white" opacity=".85"/>
        <rect x="19" y="56.5" width="44" height="2" rx="1" fill="white" opacity=".5"/>
        <rect x="19" y="61" width="50" height="2" rx="1" fill="white" opacity=".3"/>
        <circle cx="70" cy="48" r="6" fill="#2563eb"/>
        <text x="70" y="51.2" text-anchor="middle" font-size="6.5" fill="white" font-weight="bold">#1</text>
        <rect x="16" y="72" width="63" height="17" rx="3" fill="#1a2035"/>
        <rect x="19" y="75" width="38" height="2.5" rx="1.5" fill="white" opacity=".35"/>
        <rect x="19" y="79.5" width="54" height="2" rx="1" fill="white" opacity=".2"/>
        <rect x="19" y="83.5" width="40" height="2" rx="1" fill="white" opacity=".15"/>
        <rect x="16" y="93" width="63" height="14" rx="3" fill="#1a2035"/>
        <rect x="19" y="96" width="33" height="2.5" rx="1.5" fill="white" opacity=".25"/>
        <rect x="19" y="100" width="48" height="2" rx="1" fill="white" opacity=".15"/>
        <rect x="35" y="112" width="25" height="3" rx="1.5" fill="#334155"/>
      </svg>
    </div>
  </div>

  <div class="ab-foot">
    <div class="ab-offer">
      <strong>Free SEO Audit</strong>
      No commitment needed
    </div>
    <a href="https://tupate.studio/#contact" class="ab-btn">Claim Audit &rsaquo;</a>
  </div>

</div>

<style>
  .ad-banner {
    margin-top: 16px;
    width: 100%;
    background: #0f172a;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.18);
    display: grid;
    grid-template-rows: 38px 1fr 44px;
    font-family: system-ui, -apple-system, sans-serif;
  }

  .ad-banner * {
    box-sizing: border-box;
  }

  .ab-head {
    background: #2563eb;
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 0 11px;
  }

  .ab-logomark {
    width: 22px;
    height: 22px;
    background: white;
    border-radius: 5px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 900;
    font-size: 11px;
    color: #2563eb;
    flex-shrink: 0;
  }

  .ab-brandname {
    color: white;
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 0.3px;
  }

  .ab-tagline-r {
    margin-left: auto;
    color: rgba(255, 255, 255, 0.8);
    font-size: 8px;
    text-transform: uppercase;
    letter-spacing: 0.9px;
    text-align: right;
    line-height: 1.3;
  }

  .ab-body {
    display: grid;
    grid-template-columns: 1fr 96px;
  }

  .ab-text {
    padding: 12px 7px 9px 12px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 4px;
  }

  .ab-eyebrow {
    font-size: 8px;
    font-weight: 700;
    color: #60a5fa;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .ab-headline {
    font-size: 14px;
    font-weight: 800;
    color: white;
    line-height: 1.2;
  }

  .ab-headline em {
    color: #93c5fd;
    font-style: normal;
  }

  .ab-subtext {
    font-size: 10px;
    color: rgba(255, 255, 255, 0.55);
    line-height: 1.4;
  }

  .ab-em-white {
    color: white;
    font-style: normal;
  }

  .ab-visual {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 5px 8px 5px 0;
  }

  .ab-foot {
    background: #1e293b;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 11px;
  }

  .ab-offer {
    font-size: 9.5px;
    color: rgba(255, 255, 255, 0.45);
    line-height: 1.3;
  }

  .ab-offer strong {
    display: block;
    font-size: 10.5px;
    color: white;
  }

  .ab-btn {
    display: inline-flex;
    align-items: center;
    background: #2563eb;
    color: white;
    font-size: 10px;
    font-weight: 700;
    padding: 6px 12px;
    border-radius: 5px;
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.15s;
  }

  .ab-btn:hover {
    background: #1d4ed8;
  }
</style>
