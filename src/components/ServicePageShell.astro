---
import Base from '../layouts/Base.astro';
import Navbar from './Navbar.astro';
import Footer from './Footer.astro';
import QuoteForm from './QuoteForm.astro';
import { SITE } from '../config';
import { buildWhatsAppUrl } from '../lib/offers';

interface Section {
  title: string;
  paragraphs: string[];
  bullets?: string[];
  steps?: string[];
}

interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  title: string;
  description: string;
  h1: string;
  intro: string;
  eyebrow?: string;
  priceLabel: string;
  serviceName: string;
  quoteSource: string;
  quoteTitle: string;
  quoteSubtitle: string;
  heroPoints: string[];
  sections: Section[];
  faqs: FaqItem[];
  schema: Record<string, unknown>;
}

const {
  title,
  description,
  h1,
  intro,
  eyebrow = 'Service Page',
  priceLabel,
  serviceName,
  quoteSource,
  quoteTitle,
  quoteSubtitle,
  heroPoints,
  sections,
  faqs,
  schema,
} = Astro.props;

const whatsappUrl = buildWhatsAppUrl(
  SITE.whatsapp,
  `Hello Tupate Studio, I want help with ${serviceName}. Please share the next steps.`,
);

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
};
---

<Base title={title} description={description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)}></script>
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>
  </Fragment>

  <Navbar />

  <section class="service-hero">
    <div class="container service-hero-inner">
      <div class="service-hero-copy">
        <span class="service-eyebrow">{eyebrow}</span>
        <h1 class="service-title">{h1}</h1>
        <p class="service-intro">{intro}</p>

        <div class="service-actions">
          <a href="#service-quote" class="service-btn service-btn-primary">Get a quote</a>
          <a
            href={whatsappUrl}
            class="service-btn service-btn-secondary"
            target="_blank"
            rel="noopener"
            data-conversion="whatsapp"
          >
            WhatsApp us
          </a>
        </div>
      </div>

      <aside class="service-summary">
        <p class="service-price">{priceLabel}</p>
        <p class="service-summary-title">{serviceName}</p>
        <ul class="service-points">
          {heroPoints.map((point) => (
            <li>{point}</li>
          ))}
        </ul>
      </aside>
    </div>
  </section>

  <section class="service-body">
    <div class="container service-body-inner">
      <div class="service-content">
        {sections.map((section) => (
          <section class="service-section-block">
            <h2>{section.title}</h2>
            {section.paragraphs.map((paragraph) => (
              <p set:html={paragraph} />
            ))}
            {section.bullets && section.bullets.length > 0 && (
              <ul class="service-list">
                {section.bullets.map((bullet) => (
                  <li set:html={bullet} />
                ))}
              </ul>
            )}
            {section.steps && section.steps.length > 0 && (
              <ol class="service-list service-list-ordered">
                {section.steps.map((step) => (
                  <li set:html={step} />
                ))}
              </ol>
            )}
          </section>
        ))}
      </div>

      <aside class="service-side">
        <div class="service-side-card">
          <p class="service-side-title">Need a fast answer?</p>
          <p class="service-side-copy">
            If you already know what you need, send one message and we will tell you the right next step.
          </p>
          <a
            href={whatsappUrl}
            class="service-side-btn"
            target="_blank"
            rel="noopener"
            data-conversion="whatsapp"
          >
            Ask on WhatsApp
          </a>
        </div>
      </aside>
    </div>
  </section>

  <section class="service-faqs">
    <div class="container">
      <div class="faq-header">
        <span class="service-eyebrow">FAQs</span>
        <h2>Questions Kenyan business owners usually ask</h2>
      </div>

      <div class="faq-grid">
        {faqs.map((faq) => (
          <article class="faq-card">
            <h3>{faq.question}</h3>
            <p>{faq.answer}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <QuoteForm
    id="service-quote"
    source={quoteSource}
    title={quoteTitle}
    subtitle={quoteSubtitle}
    eyebrow="Request a Quote"
  />

  <Footer />
</Base>

<style>
  .service-hero {
    padding: 132px 0 72px;
    background: linear-gradient(180deg, #f6f8ff 0%, #ffffff 100%);
    border-bottom: 1px solid #e8ecf4;
  }

  .service-hero-inner {
    display: grid;
    grid-template-columns: minmax(0, 1.3fr) minmax(300px, 380px);
    gap: 36px;
    align-items: start;
  }

  .service-eyebrow {
    display: inline-block;
    padding: 6px 12px;
    border-radius: 999px;
    background: #e9efff;
    color: #2563eb;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 18px;
  }

  .service-title {
    font-size: clamp(34px, 5vw, 58px);
    line-height: 1.05;
    margin-bottom: 18px;
    max-width: 860px;
  }

  .service-intro {
    font-size: 18px;
    line-height: 1.75;
    color: #526179;
    max-width: 720px;
  }

  .service-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 30px;
  }

  .service-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 50px;
    padding: 0 24px;
    border-radius: 10px;
    font-size: 15px;
    font-weight: 700;
    text-decoration: none;
  }

  .service-btn-primary {
    background: #2563eb;
    color: #ffffff;
  }

  .service-btn-secondary {
    background: #ffffff;
    border: 1px solid #cfd8ea;
    color: #111827;
  }

  .service-summary {
    background: #ffffff;
    border: 1px solid #dfe7f5;
    border-radius: 20px;
    box-shadow: 0 18px 44px rgba(148, 163, 184, 0.12);
    padding: 28px;
  }

  .service-price {
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #2563eb;
    margin-bottom: 10px;
  }

  .service-summary-title {
    font-size: 22px;
    font-weight: 800;
    color: #111827;
    margin-bottom: 18px;
  }

  .service-points {
    list-style: none;
    display: grid;
    gap: 12px;
  }

  .service-points li {
    position: relative;
    padding-left: 18px;
    font-size: 15px;
    line-height: 1.7;
    color: #445065;
  }

  .service-points li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 10px;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #2563eb;
  }

  .service-body {
    padding: 72px 0;
    background: #ffffff;
  }

  .service-body-inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 280px;
    gap: 40px;
    align-items: start;
  }

  .service-content {
    display: grid;
    gap: 40px;
  }

  .service-section-block h2 {
    font-size: clamp(26px, 3.5vw, 38px);
    margin-bottom: 14px;
  }

  .service-section-block p {
    font-size: 17px;
    line-height: 1.8;
    color: #4f5f78;
    margin-bottom: 16px;
  }

  .service-section-block p:last-child {
    margin-bottom: 0;
  }

  .service-list {
    margin: 18px 0 0;
    padding-left: 22px;
    display: grid;
    gap: 10px;
  }

  .service-list li {
    font-size: 16px;
    line-height: 1.75;
    color: #4f5f78;
  }

  .service-list-ordered {
    padding-left: 24px;
  }

  .service-side {
    position: sticky;
    top: 100px;
  }

  .service-side-card {
    background: #f7f8fc;
    border: 1px solid #e8ecf4;
    border-radius: 18px;
    padding: 24px;
  }

  .service-side-title {
    font-size: 18px;
    font-weight: 800;
    color: #111827;
    margin-bottom: 10px;
  }

  .service-side-copy {
    font-size: 15px;
    line-height: 1.7;
    color: #5b6b84;
    margin-bottom: 18px;
  }

  .service-side-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 46px;
    width: 100%;
    border-radius: 10px;
    background: #2563eb;
    color: #ffffff;
    font-size: 15px;
    font-weight: 700;
    text-decoration: none;
  }

  .service-faqs {
    padding: 0 0 72px;
    background: #ffffff;
  }

  .faq-header {
    margin-bottom: 28px;
  }

  .faq-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
  }

  .faq-card {
    background: #f7f8fc;
    border: 1px solid #e8ecf4;
    border-radius: 18px;
    padding: 24px;
  }

  .faq-card h3 {
    font-size: 18px;
    margin-bottom: 10px;
  }

  .faq-card p {
    font-size: 15px;
    line-height: 1.7;
    color: #55657d;
  }

  @media (max-width: 960px) {
    .service-hero-inner,
    .service-body-inner,
    .faq-grid {
      grid-template-columns: 1fr;
    }

    .service-side {
      position: static;
    }
  }

  @media (max-width: 640px) {
    .service-hero {
      padding: 120px 0 56px;
    }

    .service-intro,
    .service-section-block p {
      font-size: 16px;
    }

    .service-actions {
      flex-direction: column;
    }

    .service-btn {
      width: 100%;
    }
  }
</style>
