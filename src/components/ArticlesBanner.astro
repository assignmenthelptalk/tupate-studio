---
import { articles } from '../data/articles';

// Pick a few titles to float on the right as a visual teaser
const featured = articles.slice(0, 6);
---

<section class="ab-section">
  <div class="ab-inner">

    <!-- Left: copy -->
    <div class="ab-left">
      <span class="ab-pill">Free Guides</span>
      <h2 class="ab-heading">{articles.length}+ Proven Guides to Get More Customers Online in Kenya.</h2>
      <p class="ab-sub">
        Step-by-step guides on web design, SEO, and digital marketing — built specifically for Kenyan business owners. No fluff. Just strategies that actually work.
      </p>
      <a href="/articles" class="ab-cta">Browse all guides &rarr;</a>
    </div>

    <!-- Right: floating article cards -->
    <div class="ab-right" aria-hidden="true">
      <div class="ab-cards">
        {featured.map((a, i) => (
          <div class={`ab-card ab-card--${i}`}>
            <span class="ab-card-cat">{a.category}</span>
            <p class="ab-card-title">{a.title}</p>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>

<style>
  .ab-section {
    background: #2563eb;
    padding: 0 24px;
    overflow: hidden;
  }

  .ab-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 48px;
    padding: 80px 0;
  }

  /* ── Left ── */
  .ab-left {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .ab-pill {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #93b4ff;
    background: rgba(255,255,255,0.12);
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 999px;
    padding: 5px 14px;
    margin-bottom: 24px;
  }

  .ab-heading {
    font-family: var(--font-display);
    font-size: clamp(28px, 3.5vw, 46px);
    font-weight: 800;
    color: #ffffff;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 20px;
  }

  .ab-sub {
    font-size: 16px;
    color: rgba(255,255,255,0.75);
    line-height: 1.65;
    margin-bottom: 36px;
    max-width: 420px;
  }

  .ab-cta {
    display: inline-flex;
    align-items: center;
    background: #ffffff;
    color: #2563eb;
    font-size: 15px;
    font-weight: 700;
    padding: 14px 28px;
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.18s ease, transform 0.18s ease;
  }

  .ab-cta:hover {
    background: #f0f4ff;
    transform: translateY(-1px);
  }

  /* ── Right: floating cards ── */
  .ab-right {
    position: relative;
    height: 340px;
  }

  .ab-cards {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .ab-card {
    position: absolute;
    background: #ffffff;
    border-radius: 14px;
    padding: 18px 22px;
    width: 240px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.18);
  }

  .ab-card-cat {
    display: inline-block;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #2563eb;
    margin-bottom: 8px;
  }

  .ab-card-title {
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 700;
    color: #111111;
    line-height: 1.35;
  }

  /* Card positions — staggered pile effect */
  .ab-card--0 { top: 0;    left: 0;    transform: rotate(-2deg); z-index: 1; }
  .ab-card--1 { top: 20px; left: 60px; transform: rotate(1deg);  z-index: 2; }
  .ab-card--2 { top: 120px; left: 20px; transform: rotate(-1.5deg); z-index: 3; }
  .ab-card--3 { top: 140px; left: 100px; transform: rotate(2deg); z-index: 2; }
  .ab-card--4 { top: 240px; left: 0;    transform: rotate(-1deg); z-index: 1; }
  .ab-card--5 { top: 250px; left: 110px; transform: rotate(1.5deg); z-index: 2; }

  /* Hover lifts */
  .ab-card:hover {
    z-index: 10;
    transform: rotate(0deg) translateY(-4px) !important;
    transition: transform 0.2s ease;
  }

  /* ── Mobile ── */
  @media (max-width: 860px) {
    .ab-inner {
      grid-template-columns: 1fr;
      gap: 40px;
      padding: 64px 0;
    }

    .ab-right {
      display: none;
    }
  }
</style>
