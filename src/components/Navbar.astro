---
import { SITE } from '../config';
---

<div class="nav-overlay" id="nav-overlay" aria-hidden="true"></div>
<header class="navbar" id="navbar">
  <div class="container navbar-inner">
    <a href="/" class="logo">
      <span class="logo-icon" aria-hidden="true">T</span>
      {SITE.name}
    </a>

    <nav class="nav-links" id="nav-links">
      <a href="/#services" class="menu-link">Services</a>
      <a href="/pricing" class="menu-link">Pricing</a>
      <a href="/articles" class="menu-link">Guides</a>
      <a href="/#contact" class="menu-link">Contact</a>
    </nav>

    <a
      href="/#contact"
      class="btn btn-primary nav-cta"
    >
      {SITE.ctaText}
    </a>

    <button class="mobile-toggle" id="mobile-toggle" aria-label="Toggle menu">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
</header>

<script>
  const navbar  = document.getElementById('navbar');
  const toggle  = document.getElementById('mobile-toggle');
  const navLinks = document.getElementById('nav-links');
  const overlay = document.getElementById('nav-overlay');

  function openMenu() {
    navLinks?.classList.add('open');
    toggle?.classList.add('open');
    overlay?.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    navLinks?.classList.remove('open');
    toggle?.classList.remove('open');
    overlay?.classList.remove('open');
    document.body.style.overflow = '';
  }

  window.addEventListener('scroll', () => {
    navbar?.classList.toggle('scrolled', window.scrollY > 60);
  });

  toggle?.addEventListener('click', () => {
    navLinks?.classList.contains('open') ? closeMenu() : openMenu();
  });

  overlay?.addEventListener('click', closeMenu);

  navLinks?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', closeMenu);
  });
</script>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: #ffffff;
    border-bottom: 1px solid #ebebeb;
    box-shadow: 0 1px 0 rgba(0,0,0,0.04);
  }

  .navbar-inner {
    display: flex;
    align-items: center;
    gap: 0;
    height: 72px;
  }

  /* Logo */
  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-display);
    font-size: 17px;
    font-weight: 700;
    color: #111111;
    letter-spacing: -0.01em;
    flex-shrink: 0;
    margin-right: 40px;
  }

  .logo-icon {
    width: 32px;
    height: 32px;
    background: #2563eb;
    color: #ffffff;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 15px;
    font-weight: 800;
    flex-shrink: 0;
  }

  /* Nav links — left-aligned after logo */
  .nav-links {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .nav-links a {
    font-size: 14px;
    font-weight: 500;
    color: #2563eb;
    padding: 6px 12px;
    border-radius: 6px;
    text-decoration: none;
    transition: color 0.15s ease, background 0.15s ease;
  }

  .nav-links a:hover {
    color: #1d4ed8;
    background: #f4f4f5;
  }

  /* CTA pushed to the far right */
  .nav-cta {
    margin-left: auto;
    padding: 10px 20px;
    font-size: 14px;
    flex-shrink: 0;
  }

  .mobile-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    margin-left: auto;
  }

  .nav-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    z-index: 98;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .mobile-toggle span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--dark);
    transition: transform var(--transition), opacity var(--transition), background var(--transition);
  }

  .mobile-toggle.open span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .mobile-toggle.open span:nth-child(2) {
    opacity: 0;
  }

  .mobile-toggle.open span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  @media (max-width: 768px) {
    .navbar-inner {
      gap: 10px;
    }

    .mobile-toggle {
      display: flex;
      order: 3;
      margin-left: 0;
      flex-shrink: 0;
    }

    .nav-cta {
      order: 2;
      margin-left: auto;
      font-size: 12px;
      padding: 8px 12px;
      min-height: 42px;
      white-space: nowrap;
      flex-shrink: 1;
    }

    .logo {
      margin-right: 0;
      min-width: 0;
      gap: 8px;
      font-size: 15px;
      flex: 1 1 auto;
    }

    .logo-icon {
      width: 30px;
      height: 30px;
      font-size: 14px;
    }

    .logo span,
    .logo {
      white-space: nowrap;
    }

    .nav-links {
      position: fixed;
      top: 0;
      right: 0;
      bottom: 0;
      width: min(280px, 80vw);
      flex-direction: column;
      align-items: flex-start;
      gap: 0;
      background: #ffffff;
      padding: 88px 0 32px;
      margin: 0;
      transform: translateX(100%);
      transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      box-shadow: -8px 0 32px rgba(0, 0, 0, 0.4);
      z-index: 99;
    }

    .nav-links.open {
      display: flex;
      transform: translateX(0);
    }

    .nav-links a {
      width: 100%;
      padding: 16px 28px;
      font-size: 17px;
      border-radius: 0;
      border-bottom: 1px solid #f0f0f0;
      color: #2563eb;
    }

    .nav-overlay {
      display: block;
    }

    .nav-overlay.open {
      opacity: 1;
      pointer-events: auto;
    }
  }

  @media (max-width: 480px) {
    .nav-cta {
      padding: 8px 10px;
      font-size: 11px;
    }

    .logo {
      font-size: 14px;
    }
  }
</style>
