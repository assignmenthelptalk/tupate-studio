---
import { SITE } from '../config';
---

<section class="section" id="services">
  <div class="container">
    <p class="section-label">What we do</p>
    <h2 class="section-title">Services built for Kenyan businesses</h2>
    <p class="section-sub">
      Everything you need to get online, get found, and get customers — from a
      single agency in Nairobi.
    </p>

    <div class="services-grid">
      {SITE.services.map((service) => (
        <div class="service-card">
          <span class="service-icon">{service.icon}</span>
          <h3 class="service-title">{service.title}</h3>
          <p class="service-desc">{service.description}</p>
          <p class="service-price">{service.price}</p>
        </div>
      ))}
    </div>

    <div class="objection">
      <p class="objection-q">Why not just use Wix or WordPress?</p>
      <p class="objection-a">
        Page builders ship bloated code that Google penalises and customers abandon.
        We write every line by hand — faster load times, cleaner markup, higher rankings.
        Your site won't look like everyone else's because it isn't built like everyone else's.
      </p>
    </div>
  </div>
</section>

<style>
  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 24px;
    margin-top: 48px;
  }

  .service-card {
    background: var(--light);
    border-radius: var(--radius-lg);
    padding: 32px 28px;
    border: 1.5px solid transparent;
    transition: transform 0.25s ease, box-shadow 0.25s ease,
                border-color 0.25s ease, background 0.25s ease;
  }

  .service-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04),
                0 20px 48px rgba(0, 0, 0, 0.13);
    border-color: rgba(232, 82, 26, 0.22);
    background: var(--white);
  }

  .service-icon {
    font-size: 28px;
    display: block;
    margin-bottom: 16px;
  }

  .service-title {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 700;
    color: var(--dark);
    margin-bottom: 10px;
  }

  .service-desc {
    font-size: 15px;
    color: var(--muted);
    line-height: 1.65;
    margin-bottom: 24px;
  }

  .service-price {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 15px;
    font-weight: 700;
    color: var(--accent);
    background: rgba(232, 82, 26, 0.1);
    padding: 5px 12px;
    border-radius: 999px;
    letter-spacing: -0.01em;
  }

  .objection {
    margin-top: 56px;
    padding: 32px 36px;
    background: var(--dark);
    border-radius: var(--radius-lg);
    display: flex;
    align-items: baseline;
    gap: 24px;
  }

  .objection-q {
    font-family: var(--font-display);
    font-size: 15px;
    font-weight: 700;
    color: var(--accent);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .objection-a {
    font-size: 15px;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.65;
  }

  @media (max-width: 768px) {
    .objection {
      flex-direction: column;
      gap: 12px;
      padding: 24px;
    }

    .objection-q {
      white-space: normal;
    }
  }

  @media (max-width: 768px) {
    .services-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
