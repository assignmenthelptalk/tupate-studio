---
const services = [
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>`,
    title: 'Business Website',
    price: 'Ksh 25,000',
    description:
      'Custom-coded website with the pages, forms, and WhatsApp CTA most Kenyan SMEs need to start converting.',
    cta: 'Read More ==>',
    href: '/business-website-design-kenya',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/><path d="M11 8v6M8 11h6"/></svg>`,
    title: 'SEO & Google Maps Ranking',
    price: 'Ksh 8,000/month',
    description:
      'Monthly SEO focused on search visibility, Google Maps presence, and reportable progress.',
    cta: 'Read More ==>',
    href: '/seo-google-maps-ranking-kenya',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>`,
    title: 'Website Maintenance',
    price: 'Ksh 5,000/month',
    description:
      'Monthly updates, uptime monitoring, backups, and fast support so your site keeps producing leads.',
    cta: 'Read More ==>',
    href: '/website-maintenance-services-kenya',
  },
];
---

<section class="services-section" id="services">
  <div class="container">
    <div class="section-header">
      <span class="section-pill">Core offers</span>
      <h2 class="services-heading">Start simple, then grow from the same foundation.</h2>
    </div>

    <div class="services-grid">
      {services.map((service) => (
        <div class="service-card">
          <div class="service-icon" set:html={service.icon} />
          <p class="service-price">{service.price}</p>
          <h3 class="service-name">{service.title}</h3>
          <p class="service-desc">{service.description}</p>
          <a href={service.href} class="service-cta">
            {service.cta}
          </a>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .services-section {
    background: #ffffff;
    padding: 96px 0;
  }

  .section-header {
    text-align: center;
    margin-bottom: 56px;
  }

  .section-pill {
    display: inline-block;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #444444;
    background: #f0f2f8;
    border: 1px solid #e2e6f0;
    border-radius: 999px;
    padding: 5px 14px;
    margin-bottom: 20px;
  }

  .services-heading {
    font-size: clamp(32px, 4vw, 52px);
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .service-card {
    background: #f7f8fc;
    border: 1px solid #e8ecf4;
    border-radius: 16px;
    padding: 36px 32px;
    display: flex;
    flex-direction: column;
  }

  .service-icon {
    width: 52px;
    height: 52px;
    background: #ffffff;
    border: 1px solid #e2e6f0;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
    color: #2563eb;
  }

  .service-icon svg {
    width: 22px;
    height: 22px;
  }

  .service-price {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #2563eb;
    margin-bottom: 10px;
  }

  .service-name {
    font-size: 20px;
    margin-bottom: 12px;
  }

  .service-desc {
    font-size: 15px;
    color: #666666;
    line-height: 1.65;
    flex: 1;
    margin-bottom: 24px;
  }

  .service-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 46px;
    padding: 0 18px;
    border-radius: 10px;
    background: #2563eb;
    color: #ffffff;
    font-size: 15px;
    font-weight: 700;
    text-decoration: none;
    align-self: flex-start;
  }

  @media (max-width: 900px) {
    .services-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
