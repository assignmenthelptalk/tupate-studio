          </div>
        </div>
      </div>
    </div><!-- /addon-section -->

  </div>
</section>

<style>
  .services-section {
    background: #F4F7FF;
    padding: 96px 0 80px;
  }

  .container {
    max-width: 1080px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* Header */
  .section-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #F25C2A;
    text-align: center;
    margin-bottom: 14px;
  }

  .section-title {
    font-size: clamp(28px, 4vw, 42px);
    font-weight: 800;
    color: #0E1F3D;
    text-align: center;
    line-height: 1.15;
    margin-bottom: 12px;
    letter-spacing: -0.02em;
  }

  .section-title span {
    color: #1B4FD8;
  }

  .section-sub {
    text-align: center;
    color: #6B7A99;
    font-size: 15px;
    font-weight: 400;
    max-width: 500px;
    margin: 0 auto 60px;
    line-height: 1.7;
  }

  /* Pack cards */
  .packs-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    align-items: start;
    margin-bottom: 28px;
  }

  .pack-card {
    background: #ffffff;
    border: 1.5px solid #E2E8F6;
    border-radius: 20px;
    padding: 36px 30px 32px;
    position: relative;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .pack-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 40px rgba(27, 79, 216, 0.10);
  }

  .pack-card.featured {
    background: #0E1F3D;
    border-color: #0E1F3D;
    transform: translateY(-10px);
    box-shadow: 0 24px 56px rgba(14, 31, 61, 0.25);
  }

  .pack-card.featured:hover {
    transform: translateY(-14px);
  }

  .badge {
    position: absolute;
    top: -13px;
    left: 50%;
    transform: translateX(-50%);
    background: #F25C2A;
    color: #fff;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 4px 14px;
    border-radius: 20px;
    white-space: nowrap;
  }

  .pack-icon {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
    font-size: 20px;
    background: #EEF3FF;
  }

  .pack-card.featured .pack-icon {
    background: rgba(255, 255, 255, 0.12);
  }

  .pack-name {
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 4px;
    color: #0E1F3D;
  }

  .pack-card.featured .pack-name {
    color: #fff;
  }

  .pack-tagline {
    font-size: 13px;
    color: #6B7A99;
    margin-bottom: 20px;
    line-height: 1.5;
  }

  .pack-card.featured .pack-tagline {
    color: rgba(255, 255, 255, 0.55);
  }

  .pack-price {
    font-size: 28px;
    font-weight: 800;
    color: #1B4FD8;
    margin-bottom: 2px;
  }

  .pack-card.featured .pack-price {
    color: #fff;
  }

  .pack-freq {
    font-size: 12px;
    color: #6B7A99;
    margin-bottom: 24px;
  }

  .pack-card.featured .pack-freq {
    color: rgba(255, 255, 255, 0.45);
  }

  .divider-line {
    height: 1px;
    background: #E2E8F6;
    margin-bottom: 22px;
  }

  .pack-card.featured .divider-line {
    background: rgba(255, 255, 255, 0.12);
  }

  .feature-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-bottom: 28px;
    padding: 0;
  }

  .feature-list li {
    font-size: 13.5px;
    color: #1A1A2E;
    display: flex;
    align-items: flex-start;
    gap: 10px;
    line-height: 1.5;
  }

  .pack-card.featured .feature-list li {
    color: rgba(255, 255, 255, 0.82);
  }

  .feature-list li::before {
    content: "✓";
    font-size: 12px;
    font-weight: 700;
    color: #1B4FD8;
    background: #EEF3FF;
    border-radius: 50%;
    min-width: 20px;
    height: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 1px;
    flex-shrink: 0;
  }

  .pack-card.featured .feature-list li::before {
    background: rgba(255, 255, 255, 0.15);
    color: #fff;
  }

  .pack-btn {
    display: block;
    width: 100%;
    padding: 13px;
    border-radius: 10px;
    font-size: 14px;
    font-weight: 500;
    text-align: center;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .pack-btn.outline {
    background: transparent;
    border: 1.5px solid #E2E8F6;
    color: #0E1F3D;
  }

  .pack-btn.outline:hover {
    border-color: #1B4FD8;
    color: #1B4FD8;
  }

  .pack-btn.solid {
    background: #F25C2A;
    color: #fff;
    border: 1.5px solid transparent;
  }

  .pack-btn.solid:hover {
    background: #d94d20;
  }

  /* Add-ons */
  .addon-section {
    margin-top: 60px;
  }

  .addon-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #6B7A99;
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .addon-label::before,
  .addon-label::after {
    content: '';
    flex: 1;
    height: 1px;
    background: #E2E8F6;
  }

  /* Marquee rows */
  .addon-marquee-wrap {
    overflow: hidden;
    margin-bottom: 14px;
    /* fade edges */
    mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);
  }

  .addon-track {
    display: flex;
    gap: 14px;
    width: max-content;
  }

  .addon-track--left {
    animation: scroll-left 18s linear infinite;
  }

  .addon-track--right {
    animation: scroll-right 18s linear infinite;
  }

  @keyframes scroll-left {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  @keyframes scroll-right {
    from { transform: translateX(-50%); }
    to   { transform: translateX(0); }
  }

  .addon-marquee-wrap:hover .addon-track {
    animation-play-state: paused;
  }

  .addon-card {
    background: #ffffff;
    border: 1.5px solid #E2E8F6;
    border-radius: 14px;
    padding: 22px 24px;
    display: flex;
    align-items: center;
    gap: 16px;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    /* fixed width so cards are uniform */
    width: 320px;
    flex-shrink: 0;
  }

  .addon-card:hover {
    border-color: #1B4FD8;
    box-shadow: 0 6px 20px rgba(27, 79, 216, 0.08);
  }

  .addon-icon-wrap {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: #EEF3FF;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    flex-shrink: 0;
  }

  .addon-info {
    flex: 1;
    min-width: 0;
  }

  .addon-name {
    font-size: 14px;
    font-weight: 700;
    color: #0E1F3D;
    margin-bottom: 2px;
  }

  .addon-desc {
    font-size: 12px;
    color: #6B7A99;
  }

  .addon-price {
    font-size: 14px;
    font-weight: 700;
    color: #1B4FD8;
    white-space: nowrap;
    text-align: right;
  }

  .addon-price small {
    display: block;
    font-size: 10px;
    font-weight: 400;
    color: #6B7A99;
  }

  /* Responsive */
  @media (max-width: 860px) {
    .packs-grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .pack-card.featured {
      transform: none;
    }

    .pack-card.featured:hover {
      transform: translateY(-4px);
    }

    .addon-card {
      width: 260px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .addon-track {
      animation: none;
    }
  }
</style>
