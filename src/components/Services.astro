---
import { SITE } from '../config';

const services = [
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>`,
    title: "Website Design",
    description: "Fast, hand-built websites that rank and convert. Every line of code written for your business, your keywords, and your customers in Kenya.",
    cta: "Get started",
    href: `https://wa.me/${SITE.whatsapp}?text=${encodeURIComponent(SITE.ctaWhatsappMessage)}`,
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/><path d="M11 8v6M8 11h6"/></svg>`,
    title: "SEO & Google Maps Ranking",
    description: "Local SEO that gets your business found on page 1. We handle Google Maps ranking, keyword targeting, and monthly reporting.",
    cta: "Get started",
    href: `https://wa.me/${SITE.whatsapp}?text=${encodeURIComponent(SITE.ctaWhatsappMessage)}`,
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>`,
    title: "Google Ads Management",
    description: "Targeted ad campaigns set up and managed for you. We write the copy, build the landing pages, and optimise for conversions — not just clicks.",
    cta: "Get started",
    href: `https://wa.me/${SITE.whatsapp}?text=${encodeURIComponent(SITE.ctaWhatsappMessage)}`,
  },
];
---

<section class="services-section" id="services">
  <div class="container">

    <div class="section-header">
      <span class="section-pill">What we do</span>
      <h2 class="services-heading">Here's how we can help you.</h2>
    </div>

    <div class="services-grid">
      {services.map((service) => (
        <div class="service-card">
          <div class="service-icon" set:html={service.icon} />
          <h3 class="service-name">{service.title}</h3>
          <p class="service-desc">{service.description}</p>
          <a href={service.href} class="service-cta" target="_blank" rel="noopener">
            {service.cta} →
          </a>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .services-section {
    background: #ffffff;
    padding: 96px 0;
  }

  /* ── Header ── */
  .section-header {
    text-align: center;
    margin-bottom: 56px;
  }

  .section-pill {
    display: inline-block;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #444444;
    background: #f0f2f8;
    border: 1px solid #e2e6f0;
    border-radius: 999px;
    padding: 5px 14px;
    margin-bottom: 20px;
  }

  .services-heading {
    font-family: var(--font-display);
    font-size: clamp(32px, 4vw, 52px);
    font-weight: 800;
    color: #111111;
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  /* ── 3-column grid ── */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  /* ── Card ── */
  .service-card {
    background: #f7f8fc;
    border: 1px solid #e8ecf4;
    border-radius: 16px;
    padding: 36px 32px;
    display: flex;
    flex-direction: column;
    transition: transform 0.22s ease, box-shadow 0.22s ease, border-color 0.22s ease;
  }

  .service-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 32px rgba(37, 99, 235, 0.10);
    border-color: #c5d0f5;
  }

  /* Icon circle */
  .service-icon {
    width: 52px;
    height: 52px;
    background: #ffffff;
    border: 1px solid #e2e6f0;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 24px;
    color: #2563eb;
    flex-shrink: 0;
  }

  .service-icon svg {
    width: 22px;
    height: 22px;
  }

  .service-name {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 700;
    color: #111111;
    margin-bottom: 12px;
  }

  .service-desc {
    font-size: 15px;
    color: #666666;
    line-height: 1.65;
    flex: 1;
    margin-bottom: 28px;
  }

  .service-cta {
    font-size: 15px;
    font-weight: 700;
    color: #111111;
    text-decoration: none;
    transition: color 0.15s ease;
    align-self: flex-start;
  }

  .service-cta:hover {
    color: #2563eb;
  }

  /* ── Mobile ── */
  @media (max-width: 900px) {
    .services-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
