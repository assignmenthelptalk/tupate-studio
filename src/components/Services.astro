<section class="services-section" id="services">
  <div class="container">

    <p class="section-label">What We Offer</p>
    <h2 class="section-title">Marketing that gets you <span>found &amp; chosen</span></h2>
    <p class="section-sub">Pick the pack that fits where your business is right now. You can always upgrade.</p>

    <!-- Marketing Packs -->
    <div class="packs-grid">

      <!-- Starter -->
      <div class="pack-card">
        <div class="pack-icon">📍</div>
        <div class="pack-name">Starter Pack</div>
        <div class="pack-tagline">For businesses that need to be found locally</div>
        <div class="pack-price">Ksh 8,000</div>
        <div class="pack-freq">per month</div>
        <div class="divider-line"></div>
        <ul class="feature-list">
          <li>Google Business Profile setup &amp; optimisation</li>
          <li>Monthly GBP posts, photos &amp; offers</li>
          <li>Basic on-page SEO audit + 3 page fixes</li>
          <li>WhatsApp Business setup &amp; auto-reply</li>
          <li>Monthly performance report</li>
        </ul>
        <a href="/#contact" class="pack-btn outline">Get Started →</a>
      </div>

      <!-- Growth (Featured) -->
      <div class="pack-card featured">
        <div class="badge">Most Popular</div>
        <div class="pack-icon">🚀</div>
        <div class="pack-name">Growth Pack</div>
        <div class="pack-tagline">For businesses ready to grow online consistently</div>
        <div class="pack-price">Ksh 18,000</div>
        <div class="pack-freq">per month</div>
        <div class="divider-line"></div>
        <ul class="feature-list">
          <li>Everything in Starter Pack</li>
          <li>Full SEO management – keywords, on-page, technical</li>
          <li>Social media setup on 2 platforms</li>
          <li>8 posts/month with graphics &amp; captions</li>
          <li>Google review response management</li>
          <li>Monthly analytics report with insights</li>
        </ul>
        <a href="/#contact" class="pack-btn solid">Get Started →</a>
      </div>

      <!-- Pro -->
      <div class="pack-card">
        <div class="pack-icon">🏆</div>
        <div class="pack-name">Pro Pack</div>
        <div class="pack-tagline">For businesses that want to dominate their niche</div>
        <div class="pack-price">Ksh 35,000</div>
        <div class="pack-freq">per month</div>
        <div class="divider-line"></div>
        <ul class="feature-list">
          <li>Everything in Growth Pack</li>
          <li>12 posts/month across 3 platforms</li>
          <li>2 SEO blog articles per month</li>
          <li>Google Ads management</li>
          <li>Quarterly competitor analysis</li>
          <li>Priority support + monthly strategy call</li>
        </ul>
        <a href="/#contact" class="pack-btn outline">Get Started →</a>
      </div>

    </div><!-- /packs-grid -->

    <!-- Add-on Services -->
    <div class="addon-section">
      <div class="addon-label">Website &amp; Add-on Services</div>

      <!-- Row 1: scrolls right → left -->
      <div class="addon-marquee-wrap">
        <div class="addon-track addon-track--left">
          <div class="addon-card">
            <div class="addon-icon-wrap">🖥️</div>
            <div class="addon-info">
              <div class="addon-name">Website Build</div>
              <div class="addon-desc">5-page custom site, mobile-ready</div>
            </div>
            <div class="addon-price">Ksh 30,000 <small>one-time</small></div>
          </div>
          <div class="addon-card">
            <div class="addon-icon-wrap">🎨</div>
            <div class="addon-info">
              <div class="addon-name">Website Redesign</div>
              <div class="addon-desc">Modernise your existing site</div>
            </div>
            <div class="addon-price">Ksh 20,000 <small>one-time</small></div>
          </div>
          <div class="addon-card">
            <div class="addon-icon-wrap">🛡️</div>
            <div class="addon-info">
              <div class="addon-name">Website Maintenance</div>
              <div class="addon-desc">Updates, backups, uptime monitoring</div>
            </div>
            <div class="addon-price">Ksh 3,000 <small>/month</small></div>
          </div>
          <!-- duplicates for seamless loop -->
          <div class="addon-card" aria-hidden="true">
            <div class="addon-icon-wrap">🖥️</div>
            <div class="addon-info">
              <div class="addon-name">Website Build</div>
              <div class="addon-desc">5-page custom site, mobile-ready</div>
            </div>
            <div class="addon-price">Ksh 30,000 <small>one-time</small></div>
          </div>
          <div class="addon-card" aria-hidden="true">
            <div class="addon-icon-wrap">🎨</div>
            <div class="addon-info">
              <div class="addon-name">Website Redesign</div>
              <div class="addon-desc">Modernise your existing site</div>
            </div>
            <div class="addon-price">Ksh 20,000 <small>one-time</small></div>
          </div>
          <div class="addon-card" aria-hidden="true">
            <div class="addon-icon-wrap">🛡️</div>
            <div class="addon-info">
              <div class="addon-name">Website Maintenance</div>
              <div class="addon-desc">Updates, backups, uptime monitoring</div>
            </div>
            <div class="addon-price">Ksh 3,000 <small>/month</small></div>
          </div>
        </div>
      </div>

      <!-- Row 2: scrolls left → right -->
      <div class="addon-marquee-wrap">
        <div class="addon-track addon-track--right">
          <div class="addon-card">
            <div class="addon-icon-wrap">📄</div>
            <div class="addon-info">
              <div class="addon-name">Landing Page</div>
              <div class="addon-desc">Single high-conversion page</div>
            </div>
            <div class="addon-price">Ksh 10,000 <small>one-time</small></div>
          </div>
          <div class="addon-card">
            <div class="addon-icon-wrap">🔍</div>
            <div class="addon-info">
              <div class="addon-name">Site Audit</div>
              <div class="addon-desc">Speed, SEO &amp; UX full report</div>
            </div>
            <div class="addon-price">Ksh 5,000 <small>one-time</small></div>
          </div>
          <div class="addon-card">
            <div class="addon-icon-wrap">📢</div>
            <div class="addon-info">
              <div class="addon-name">Google Ads Setup</div>
              <div class="addon-desc">Campaign setup &amp; configuration</div>
            </div>
            <div class="addon-price">Ksh 8,000 <small>one-time</small></div>
          </div>
          <!-- duplicates for seamless loop -->
          <div class="addon-card" aria-hidden="true">
            <div class="addon-icon-wrap">📄</div>
            <div class="addon-info">
              <div class="addon-name">Landing Page</div>
              <div class="addon-desc">Single high-conversion page</div>
            </div>
            <div class="addon-price">Ksh 10,000 <small>one-time</small></div>
          </div>
          <div class="addon-card" aria-hidden="true">
            <div class="addon-icon-wrap">🔍</div>
            <div class="addon-info">
              <div class="addon-name">Site Audit</div>
              <div class="addon-desc">Speed, SEO &amp; UX full report</div>
            </div>
            <div class="addon-price">Ksh 5,000 <small>one-time</small></div>
          </div>
          <div class="addon-card" aria-hidden="true">
            <div class="addon-icon-wrap">📢</div>
            <div class="addon-info">
              <div class="addon-name">Google Ads Setup</div>
              <div class="addon-desc">Campaign setup &amp; configuration</div>
            </div>
