---
import { SITE } from '../config';

const cards = [
  {
    title: 'Found on Google Maps',
    desc: 'We optimise your Google Business Profile so customers searching nearby see you first.',
  },
  {
    title: 'Active on social media',
    desc: 'Up to 12 posts/month with graphics and captions — done for you, every month.',
  },
  {
    title: 'Monthly performance reports',
    desc: 'Clear numbers showing rankings, reach, and leads — so you always know what is working.',
  },
  {
    title: 'SEO that compounds',
    desc: 'Rankings build month over month. The longer you run, the harder you are to displace.',
  },
  {
    title: 'WhatsApp-ready leads',
    desc: 'Enquiries come straight to your WhatsApp — no login, no dashboard, no chasing.',
  },
  {
    title: 'Website add-ons available',
    desc: 'Need a site or redesign? Add it to any pack. Delivered in 10-14 days.',
  },
];
---

<section class="spotlight-section">
  <div class="container spotlight-inner">
    <div class="spotlight-left">
      <span class="spotlight-pill">Why Tupate</span>
      <h2 class="spotlight-heading">Marketing that works while you run your business.</h2>
      <p class="spotlight-sub">
        We handle your Google presence, SEO, and social media every month — so you get consistent leads without doing it yourself.
      </p>
      <a href="/#contact" class="spotlight-cta">
        Start your quote
      </a>

      <div class="spotlight-stats">
        {SITE.stats.map((stat) => (
          <div class="spotlight-stat">
            <span class="spotlight-stat-value">{stat.value}</span>
            <span class="spotlight-stat-label">{stat.label}</span>
          </div>
        ))}
      </div>

      <div class="spotlight-photo-wrap">
        <img
          src="/businessman-nairobi.png"
          alt="Kenyan business owner with a professional website"
          class="spotlight-photo"
          loading="lazy"
        />
      </div>
    </div>

    <div class="spotlight-right">
      <div class="spotlight-track">
        {[...cards, ...cards].map((card) => (
          <div class="scroll-card">
            <p class="scroll-card-title">{card.title}</p>
            <p class="scroll-card-desc">{card.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .spotlight-section {
    background: #ffffff;
    padding: 96px 0;
    border-top: 1px solid #e8ecf4;
  }

  .spotlight-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 56px;
    align-items: start;
  }

  .spotlight-left {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .spotlight-pill {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #2563eb;
    background: #eff3ff;
    border: 1px solid #c7d5fc;
    border-radius: 999px;
    padding: 5px 14px;
    margin-bottom: 24px;
  }

  .spotlight-heading {
    font-size: clamp(28px, 3.5vw, 44px);
    line-height: 1.12;
    letter-spacing: -0.02em;
    margin-bottom: 20px;
  }

  .spotlight-sub {
    font-size: 16px;
    color: #666666;
    line-height: 1.65;
    margin-bottom: 24px;
    max-width: 440px;
  }

  .spotlight-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 24px;
    border-radius: 8px;
    background: #2563eb;
    color: #ffffff;
    font-size: 15px;
    font-weight: 700;
    text-decoration: none;
    margin-bottom: 36px;
  }

  .spotlight-stats {
    display: grid;
    gap: 18px;
  }

  .spotlight-stat {
    display: grid;
    gap: 4px;
  }

  .spotlight-stat-value {
    font-size: 36px;
    font-weight: 800;
    color: #3d5af1;
    line-height: 1;
  }

  .spotlight-stat-label {
    font-size: 11px;
    font-weight: 600;
    color: #999999;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .spotlight-photo-wrap {
    margin-top: 32px;
    border-radius: 16px;
    overflow: hidden;
    max-width: 360px;
  }

  .spotlight-photo {
    width: 100%;
    height: auto;
    display: block;
  }

  .spotlight-right {
    position: relative;
    max-height: 720px;
    overflow: hidden;
  }

  .spotlight-right::before,
  .spotlight-right::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    height: 72px;
    z-index: 1;
    pointer-events: none;
  }

  .spotlight-right::before {
    top: 0;
    background: linear-gradient(180deg, #ffffff 0%, rgba(255, 255, 255, 0) 100%);
  }

  .spotlight-right::after {
    bottom: 0;
    background: linear-gradient(0deg, #ffffff 0%, rgba(255, 255, 255, 0) 100%);
  }

  .spotlight-track {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
    animation: spotlight-scroll 22s linear infinite;
  }

  .scroll-card {
    background: #f7f8fc;
    border: 1px solid #e8ecf4;
    border-radius: 14px;
    padding: 22px;
  }

  .scroll-card-title {
    font-size: 15px;
    font-weight: 700;
    color: #111111;
    margin-bottom: 6px;
  }

  .scroll-card-desc {
    font-size: 14px;
    color: #666666;
    line-height: 1.6;
  }

  @keyframes spotlight-scroll {
    from {
      transform: translateY(0);
    }

    to {
      transform: translateY(calc(-50% - 7px));
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .spotlight-track {
      animation: none;
    }
  }

  @media (max-width: 900px) {
    .spotlight-inner {
      grid-template-columns: 1fr;
    }

    .spotlight-right {
      max-height: none;
      overflow: visible;
    }

    .spotlight-right::before,
    .spotlight-right::after {
      display: none;
    }

    .spotlight-track {
      grid-template-columns: 1fr;
      animation: none;
    }
  }
</style>
