---
import { SITE } from '../config';

const cards = [
  {
    title: 'Same offers on every page',
    desc: 'Website, SEO, and maintenance now use one consistent pricing story across the site.',
  },
  {
    title: 'Quote form plus WhatsApp',
    desc: 'Visitors can either submit a short form or start the conversation on WhatsApp immediately.',
  },
  {
    title: 'Built for lead capture',
    desc: 'The site now pushes people toward quote requests instead of making them hunt for the next step.',
  },
  {
    title: 'Delivered in 10-14 days',
    desc: 'The core website offer stays fast, clear, and easy to buy.',
  },
  {
    title: 'SEO from Ksh 8,000/month',
    desc: 'Organic growth stays positioned as the next step after the website is live.',
  },
  {
    title: 'Maintenance from Ksh 5,000/month',
    desc: 'Support pricing now matches the pricing page and article content.',
  },
];
---

<section class="spotlight-section">
  <div class="container spotlight-inner">
    <div class="spotlight-left">
      <span class="spotlight-pill">Why Tupate</span>
      <h2 class="spotlight-heading">A simple funnel beats a prettier homepage.</h2>
      <p class="spotlight-sub">
        This site now leads with one website offer, clear follow-on retainers, and two ways to convert:
        the short quote form or WhatsApp.
      </p>
      <a href="/#contact" class="spotlight-cta">
        Start your quote
      </a>

      <div class="spotlight-stats">
        {SITE.stats.map((stat) => (
          <div class="spotlight-stat">
            <span class="spotlight-stat-value">{stat.value}</span>
            <span class="spotlight-stat-label">{stat.label}</span>
          </div>
        ))}
      </div>

      <div class="spotlight-photo-wrap">
        <img
          src="/businessman-nairobi.png"
          alt="Kenyan business owner with a professional website"
          class="spotlight-photo"
          loading="lazy"
        />
      </div>
    </div>

    <div class="spotlight-right">
      {cards.map((card) => (
        <div class="scroll-card">
          <p class="scroll-card-title">{card.title}</p>
          <p class="scroll-card-desc">{card.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .spotlight-section {
    background: #ffffff;
    padding: 96px 0;
    border-top: 1px solid #e8ecf4;
  }

  .spotlight-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 56px;
    align-items: start;
  }

  .spotlight-left {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .spotlight-pill {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #2563eb;
    background: #eff3ff;
    border: 1px solid #c7d5fc;
    border-radius: 999px;
    padding: 5px 14px;
    margin-bottom: 24px;
  }

  .spotlight-heading {
    font-size: clamp(28px, 3.5vw, 44px);
    line-height: 1.12;
    letter-spacing: -0.02em;
    margin-bottom: 20px;
  }

  .spotlight-sub {
    font-size: 16px;
    color: #666666;
    line-height: 1.65;
    margin-bottom: 24px;
    max-width: 440px;
  }

  .spotlight-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 24px;
    border-radius: 8px;
    background: #2563eb;
    color: #ffffff;
    font-size: 15px;
    font-weight: 700;
    text-decoration: none;
    margin-bottom: 36px;
  }

  .spotlight-stats {
    display: grid;
    gap: 18px;
  }

  .spotlight-stat {
    display: grid;
    gap: 4px;
  }

  .spotlight-stat-value {
    font-size: 36px;
    font-weight: 800;
    color: #3d5af1;
    line-height: 1;
  }

  .spotlight-stat-label {
    font-size: 11px;
    font-weight: 600;
    color: #999999;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .spotlight-photo-wrap {
    margin-top: 32px;
    border-radius: 16px;
    overflow: hidden;
    max-width: 360px;
  }

  .spotlight-photo {
    width: 100%;
    height: auto;
    display: block;
  }

  .spotlight-right {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
    max-height: 720px;
    overflow-y: auto;
    padding-right: 8px;
  }

  .scroll-card {
    background: #f7f8fc;
    border: 1px solid #e8ecf4;
    border-radius: 14px;
    padding: 22px;
  }

  .scroll-card-title {
    font-size: 15px;
    font-weight: 700;
    color: #111111;
    margin-bottom: 6px;
  }

  .scroll-card-desc {
    font-size: 14px;
    color: #666666;
    line-height: 1.6;
  }

  .spotlight-right::-webkit-scrollbar {
    width: 10px;
  }

  .spotlight-right::-webkit-scrollbar-track {
    background: #eef2f8;
    border-radius: 999px;
  }

  .spotlight-right::-webkit-scrollbar-thumb {
    background: #c8d4ea;
    border-radius: 999px;
    border: 2px solid #eef2f8;
  }

  @media (max-width: 900px) {
    .spotlight-inner {
      grid-template-columns: 1fr;
    }

    .spotlight-right {
      grid-template-columns: 1fr;
      max-height: none;
      overflow: visible;
      padding-right: 0;
    }
  }
</style>
