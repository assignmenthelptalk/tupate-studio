---
import { SITE } from '../config';

const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-main">

    <!-- Brand col -->
    <div class="footer-brand">
      <a href="/" class="footer-logo">
        <div class="footer-logo-icon">T</div>
        <span>{SITE.name}</span>
      </a>
      <p class="footer-tagline">{SITE.tagline}</p>
      <div class="footer-social">
        {SITE.social.twitter && (
          <a href={SITE.social.twitter} target="_blank" rel="noopener" aria-label="Twitter/X">
            <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.737-8.835L1.254 2.25H8.08l4.253 5.622L18.244 2.25zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z"/></svg>
          </a>
        )}
        {SITE.social.instagram && (
          <a href={SITE.social.instagram} target="_blank" rel="noopener" aria-label="Instagram">
            <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
        )}
        {SITE.social.linkedin && (
          <a href={SITE.social.linkedin} target="_blank" rel="noopener" aria-label="LinkedIn">
            <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
        )}
      </div>
    </div>

    <!-- Services col -->
    <nav class="footer-nav">
      <p class="footer-nav-title">Services</p>
      <a href="/#services" class="menu-link">Website Design</a>
      <a href="/#services" class="menu-link">SEO & Google Maps</a>
      <a href="/#services" class="menu-link">Google Ads</a>
      <a href="/#services" class="menu-link">Website Maintenance</a>
    </nav>

    <!-- Resources col -->
    <nav class="footer-nav">
      <p class="footer-nav-title">Free Guides</p>
      <a href="/articles" class="menu-link">All Articles</a>
      <a href="/articles/website-design-kenya" class="menu-link">Website Design Kenya</a>
      <a href="/articles/seo-services-kenya" class="menu-link">SEO Services Kenya</a>
      <a href="/articles/google-ads-kenya" class="menu-link">Google Ads Kenya</a>
    </nav>

    <!-- Company col -->
    <nav class="footer-nav">
      <p class="footer-nav-title">Company</p>
      <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
      <a href={`tel:${SITE.phone}`}>{SITE.phone}</a>
      <a href={`https://wa.me/${SITE.whatsapp}?text=${encodeURIComponent(SITE.ctaWhatsappMessage)}`} target="_blank" rel="noopener">WhatsApp Us</a>
    </nav>

  </div>

  <!-- Bottom bar -->
  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <p>© {year} Tupate Limited. All rights reserved.</p>
      <div class="footer-bottom-links">
        <a href="/articles/kenya-data-protection-act" class="menu-link">Privacy Policy</a>
        <a href={`mailto:${SITE.email}`}>Contact</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: #ffffff;
    border-top: 1px solid #e8ecf4;
  }

  /* ── Main grid ── */
  .footer-main {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 48px;
    padding-top: 64px;
    padding-bottom: 56px;
    align-items: start;
  }

  /* ── Brand ── */
  .footer-logo {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    margin-bottom: 14px;
  }

  .footer-logo-icon {
    width: 36px;
    height: 36px;
    background: #2563eb;
    color: #ffffff;
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 800;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .footer-logo span {
    font-family: var(--font-display);
    font-size: 17px;
    font-weight: 700;
    color: #111111;
  }

  .footer-tagline {
    font-size: 14px;
    color: #888888;
    line-height: 1.6;
    max-width: 240px;
    margin-bottom: 22px;
  }

  .footer-social {
    display: flex;
    gap: 14px;
  }

  .footer-social a {
    color: #aaaaaa;
    transition: color 0.15s ease;
    display: flex;
    align-items: center;
  }

  .footer-social a:hover {
    color: #2563eb;
  }

  /* ── Nav cols ── */
  .footer-nav {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer-nav-title {
    font-size: 13px;
    font-weight: 700;
    color: #111111;
    margin-bottom: 4px;
  }

  .footer-nav a {
    font-size: 14px;
    color: #2563eb;
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .footer-nav a:hover {
    color: #1d4ed8;
  }

  /* ── Bottom bar ── */
  .footer-bottom {
    border-top: 1px solid #e8ecf4;
    padding: 20px 0;
  }

  .footer-bottom-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
  }

  .footer-bottom-inner p {
    font-size: 13px;
    color: #aaaaaa;
  }

  .footer-bottom-links {
    display: flex;
    gap: 24px;
  }

  .footer-bottom-links a {
    font-size: 13px;
    color: #2563eb;
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .footer-bottom-links a:hover {
    color: #1d4ed8;
  }

  /* ── Mobile ── */
  @media (max-width: 900px) {
    .footer-main {
      grid-template-columns: 1fr 1fr;
      gap: 36px;
    }

    .footer-brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 520px) {
    .footer-main {
      grid-template-columns: 1fr;
    }

    .footer-bottom-inner {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
