---
import { SITE } from '../config';
---

<section class="hero">
  <div class="container hero-inner">

    <!-- LEFT -->
    <div class="hero-left">

      <div class="hero-badge">
        <span class="badge-dot" aria-hidden="true"></span>
        KENYAN-OWNED &nbsp;·&nbsp; Serving businesses across Kenya →
      </div>

      <h1 class="hero-title">
        Your competitors<br>are on Google.<br>
        We'll make sure you<br><em>outrank them.</em>
      </h1>

      <p class="hero-sub">
        Your customers are searching right now. Make sure they find you,
        not someone else.
      </p>

      <p class="hero-trust">No templates. No AI garbage. Just hand-coded sites that bring in real visitors.</p>

      <div class="hero-buttons">
        <a
          href={`https://wa.me/${SITE.whatsapp}?text=${encodeURIComponent(SITE.ctaWhatsappMessage)}`}
          class="btn btn-primary"
          target="_blank"
          rel="noopener"
        >
          Get a free quote →
        </a>
        <a href="#services" class="btn btn-secondary">See our services</a>
      </div>


    </div>

    <!-- RIGHT -->
    <div class="hero-right">
      <div class="photo-wrap">

        <div class="photo-placeholder">
          <div class="photo-inner">
            <div class="photo-icon" aria-hidden="true">📸</div>
            <span>Your photo here</span>
          </div>
        </div>

        <!-- Floating badge 1 — bottom left -->
        <div class="float-badge-1">
          <div class="float-icon">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
            </svg>
          </div>
          <div class="float-text">
            <strong>50+ Websites</strong>
            <span>Delivered across Kenya</span>
          </div>
        </div>

        <!-- Floating badge 2 — top right -->
        <div class="float-badge-2">
          <span class="pulse-dot" aria-hidden="true"></span>
          <span>Delivered in 2 weeks</span>
        </div>

      </div>
    </div>

  </div>
</section>

<style>
  .hero {
    background: #ffffff;
    padding: 140px 0 100px;
    min-height: 100vh;
    display: flex;
    align-items: center;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
    width: 100%;
  }

  /* ── LEFT ── */
  .hero-left {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  /* Badge */
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #111111;
    color: #ffffff;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.04em;
    padding: 6px 14px;
    border-radius: 999px;
    margin-bottom: 28px;
    opacity: 0;
    transform: translateY(8px);
    animation: fadeUp 0.5s ease forwards 0.1s;
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    background: #e8590c;
    border-radius: 50%;
    flex-shrink: 0;
  }

  /* Headline */
  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(38px, 5.5vw, 64px);
    font-weight: 800;
    color: #111111;
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin-bottom: 0;
    opacity: 0;
    transform: translateY(12px);
    animation: fadeUp 0.55s ease forwards 0.2s;
  }

  .hero-title em {
    font-style: normal;
    color: #e8590c;
  }

  /* Subheadline */
  .hero-sub {
    font-size: 18px;
    color: #666666;
    line-height: 1.65;
    max-width: 460px;
    margin-top: 24px;
    opacity: 0;
    transform: translateY(12px);
    animation: fadeUp 0.55s ease forwards 0.32s;
  }

  /* Buttons */
  .hero-buttons {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 28px;
    opacity: 0;
    transform: translateY(12px);
    animation: fadeUp 0.55s ease forwards 0.56s;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 700;
    padding: 15px 28px;
    border-radius: 6px;
    text-decoration: none;
    border: 2px solid transparent;
    transition: background 0.2s ease, transform 0.2s ease,
                border-color 0.2s ease, color 0.2s ease;
    min-height: 50px;
  }

  .btn-primary {
    background: #2563eb;
    color: #ffffff;
    border-color: #2563eb;
  }

  .btn-primary:hover {
    background: #1d4ed8;
    border-color: #1d4ed8;
    transform: translateY(-2px);
  }

  .btn-secondary {
    background: #ffffff;
    color: #111111;
    border-color: #111111;
  }

  .btn-secondary:hover {
    background: #111111;
    color: #ffffff;
    transform: translateY(-2px);
  }

  /* Trust line */
  .hero-trust {
    font-family: 'Caveat', cursive;
    font-size: 22px;
    font-weight: 600;
    color: #888888;
    margin-top: 24px;
    margin-bottom: 0;
    opacity: 0;
    transform: translateY(8px);
    animation: fadeUp 0.5s ease forwards 0.44s;
  }

  .hero-trust::before {
    content: '← ';
    color: #e8590c;
  }

  /* ── RIGHT ── */
  .hero-right {
    opacity: 0;
    transform: translateX(16px);
    animation: fadeRight 0.6s ease forwards 0.3s;
  }

  .photo-wrap {
    position: relative;
    width: 100%;
  }

  .photo-placeholder {
    width: 100%;
    aspect-ratio: 4 / 4.8;
    background: #f7f7f5;
    border-radius: 12px;
    border: 1px solid #e5e5e5;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .photo-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    color: #888888;
    font-size: 14px;
    font-weight: 500;
  }

  .photo-icon {
    width: 48px;
    height: 48px;
    background: #e5e5e5;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
  }

  /* Floating badge 1 — bottom left */
  .float-badge-1 {
    position: absolute;
    bottom: -16px;
    left: -20px;
    background: #ffffff;
    border: 1px solid #e5e5e5;
    border-radius: 10px;
    padding: 14px 18px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.10);
    display: flex;
    align-items: center;
    gap: 12px;
    min-width: 200px;
    white-space: nowrap;
  }

  .float-icon {
    width: 36px;
    height: 36px;
    background: #e8590c;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .float-icon svg {
    width: 18px;
    height: 18px;
    fill: #ffffff;
  }

  .float-text strong {
    display: block;
    font-size: 15px;
    font-weight: 800;
    color: #111111;
    line-height: 1.2;
  }

  .float-text span {
    font-size: 12px;
    color: #888888;
  }

  /* Floating badge 2 — top right */
  .float-badge-2 {
    position: absolute;
    top: 24px;
    right: -20px;
    background: #111111;
    border-radius: 10px;
    padding: 12px 16px;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.20);
    display: flex;
    align-items: center;
    gap: 8px;
    white-space: nowrap;
  }

  .float-badge-2 span:last-child {
    font-size: 13px;
    font-weight: 700;
    color: #ffffff;
  }

  .pulse-dot {
    width: 8px;
    height: 8px;
    background: #22c55e;
    border-radius: 50%;
    flex-shrink: 0;
    animation: pulse 2s infinite;
  }

  /* ── Animations ── */
  @keyframes fadeUp {
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes fadeRight {
    to { opacity: 1; transform: translateX(0); }
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.6; transform: scale(1.3); }
  }

  /* ── MOBILE ── */
  @media (max-width: 768px) {
    .hero {
      padding: 104px 0 80px;
      min-height: auto;
      align-items: flex-start;
    }

    .hero-inner {
      grid-template-columns: 1fr;
      gap: 48px;
    }

    .hero-right {
      order: -1;
    }

    .photo-placeholder {
      aspect-ratio: 4 / 3;
    }

    .hero-title {
      font-size: clamp(32px, 9vw, 40px);
    }

    .hero-sub {
      font-size: 16px;
      max-width: 100%;
    }

    .hero-buttons {
      flex-direction: column;
      width: 100%;
    }

    .btn {
      width: 100%;
      justify-content: center;
    }

    .float-badge-1 {
      bottom: -12px;
      left: 12px;
    }

    .float-badge-2 {
      top: 12px;
      right: 12px;
    }

    .hero-trust {
      font-size: 20px;
    }
  }

  @media (max-width: 375px) {
    .hero-title {
      font-size: 34px;
    }
  }
</style>
