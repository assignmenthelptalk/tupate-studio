---
import { SITE } from '../config';
---

<section class="hero">
  <div class="container hero-inner">
    <div class="hero-left">
      <h1 class="hero-title">We build websites that pay for themselves by bringing you customers- Guaranteed</h1>

      <p class="hero-sub">
        Start with a custom website from Ksh 25,000, then grow with SEO at Ksh 8,000/month
        or maintenance at Ksh 5,000/month when you are ready.
      </p>

      <p class="hero-trust">Short quote form plus WhatsApp. No long sales process.</p>

      <div class="hero-buttons">
        <a href="/#contact" class="btn btn-primary">
          Get a quote
        </a>
        <a
          href={`https://wa.me/${SITE.whatsapp}?text=${encodeURIComponent(SITE.ctaWhatsappMessage)}`}
          class="btn btn-secondary"
          target="_blank"
          rel="noopener"
          data-conversion="whatsapp"
        >
          WhatsApp us
        </a>
      </div>
    </div>

    <div class="hero-right">
      <div class="photo-wrap">
        <img
          src="/founders.png"
          alt="Tupate Studio founders"
          class="hero-photo"
        />
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    background-color: #eef1fb;
    background-image:
      linear-gradient(135deg, #f5f7ff 0%, #e8eeff 60%, #dde4fc 100%);
    padding: 120px 0 64px;
    min-height: 100vh;
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
    box-sizing: border-box;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(99, 120, 230, 0.1) 1px, transparent 1px),
      linear-gradient(90deg, rgba(99, 120, 230, 0.1) 1px, transparent 1px);
    background-size: 36px 36px;
    mask-image: radial-gradient(ellipse 70% 80% at 80% 30%, black 20%, transparent 75%);
    -webkit-mask-image: radial-gradient(ellipse 70% 80% at 80% 30%, black 20%, transparent 75%);
    pointer-events: none;
  }

  .hero::after {
    content: '';
    position: absolute;
    right: -2%;
    top: 50%;
    transform: translateY(-50%);
    width: 52%;
    aspect-ratio: 1;
    border-radius: 50%;
    background: radial-gradient(circle, #c7d3f8 0%, #b8c8f5 40%, transparent 70%);
    opacity: 0.55;
    pointer-events: none;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: 48px;
    align-items: center;
    width: 100%;
    position: relative;
    z-index: 1;
  }

  .hero-left {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .hero-title {
    font-size: clamp(38px, 5.5vw, 64px);
    font-weight: 800;
    color: #111111;
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin-bottom: 0;
  }

  .hero-title em {
    font-style: normal;
    color: #e8590c;
  }

  .hero-sub {
    font-size: 18px;
    color: #666666;
    line-height: 1.65;
    max-width: 540px;
    margin-top: 24px;
  }

  .hero-buttons {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 28px;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    min-height: 50px;
    padding: 0 28px;
    border-radius: 6px;
    font-size: 15px;
    font-weight: 700;
    text-decoration: none;
    border: 2px solid transparent;
    transition: background 0.2s ease, transform 0.2s ease,
      border-color 0.2s ease, color 0.2s ease;
  }

  .btn-primary {
    background: #2563eb;
    color: #ffffff;
    border-color: #2563eb;
  }

  .btn-primary:hover {
    background: #1d4ed8;
    border-color: #1d4ed8;
    transform: translateY(-2px);
  }

  .btn-secondary {
    background: #ffffff;
    color: #111111;
    border-color: #111111;
  }

  .btn-secondary:hover {
    background: #111111;
    color: #ffffff;
    transform: translateY(-2px);
  }

  .hero-trust {
    font-family: 'Caveat', cursive;
    font-size: 22px;
    font-weight: 600;
    color: #4361ee;
    margin-top: 24px;
  }

  .hero-trust::before {
    content: '<- ';
  }

  .photo-wrap {
    position: relative;
    width: 100%;
  }

  .hero-photo {
    width: 100%;
    max-height: 78vh;
    object-fit: cover;
    object-position: center top;
    border-radius: 16px;
    display: block;
  }

  @media (max-width: 768px) {
    .hero {
      height: auto;
      min-height: 100vh;
      padding: 100px 0 80px;
      align-items: flex-start;
    }

    .hero-inner {
      grid-template-columns: 1fr;
      gap: 48px;
    }

    .hero-right {
      order: -1;
    }

    .hero-title {
      font-size: clamp(32px, 9vw, 40px);
    }

    .hero-sub {
      font-size: 16px;
      max-width: 100%;
    }

    .hero-buttons {
      flex-direction: column;
      width: 100%;
    }

    .btn {
      width: 100%;
    }

    .hero-trust {
      font-size: 20px;
    }
  }

  @media (max-width: 375px) {
    .hero-title {
      font-size: 34px;
    }
  }
</style>
