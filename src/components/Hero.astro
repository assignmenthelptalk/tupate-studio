---
import { SITE } from '../config';
---

<section class="hero">
  <div class="container hero-inner">

    <!-- LEFT -->
    <div class="hero-left">

      <div class="hero-badge">
        <span class="badge-dot" aria-hidden="true"></span>
        9 years turning websites into customer machines.
      </div>

      <h1 class="hero-title">
        Your competitors<br>are on Google.<br>
        We'll make sure you<br><em>outrank them.</em>
      </h1>

      <p class="hero-sub">
        Your customers are searching right now. Make sure they find you,
        not someone else.
      </p>

      <p class="hero-trust">A website built to get you customers, not an AI-made site that won't rank on Google.</p>

      <div class="hero-buttons">
        <a
          href={`https://wa.me/${SITE.whatsapp}?text=${encodeURIComponent(SITE.ctaWhatsappMessage)}`}
          class="btn btn-primary"
          target="_blank"
          rel="noopener"
        >
          Get a free quote →
        </a>
        <a href="#services" class="btn btn-secondary">See our services</a>
      </div>


    </div>

    <!-- RIGHT -->
    <div class="hero-right">
      <div class="photo-wrap">

        <!-- SEO illustration — mock Google SERP -->
        <div class="seo-card" aria-hidden="true">

          <!-- Search bar -->
          <div class="serp-search">
            <svg class="serp-g-logo" viewBox="0 0 24 24"><path d="M21.35 11.1h-9.17v2.73h6.51c-.33 3.81-3.5 5.44-6.5 5.44C8.36 19.27 5 16.28 5 12c0-4.2 3.29-7.27 7.19-7.27 3.09 0 4.9 1.97 4.9 1.97L19 4.72S16.56 2 12.1 2C6.42 2 2.03 6.8 2.03 12c0 5.05 4.13 10 10.22 10 5.35 0 9.25-3.67 9.25-9.09 0-1.15-.15-1.81-.15-1.81z" fill="#4285F4"/></svg>
            <span class="serp-query">web design nairobi</span>
            <svg class="serp-search-icon" viewBox="0 0 24 24"><path d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z" stroke="#666" stroke-width="2" fill="none" stroke-linecap="round"/></svg>
          </div>

          <div class="serp-meta">About 4,820 results (0.42 seconds)</div>

          <!-- Result #1 — highlighted -->
          <div class="serp-result serp-result--first">
            <div class="serp-rank">
              <span class="rank-num">1</span>
            </div>
            <div class="serp-content">
              <div class="serp-url">
                <span class="serp-favicon">🌐</span>
                <span>yourclient.co.ke</span>
              </div>
              <div class="serp-title">Your Business Name — Nairobi, Kenya</div>
              <div class="serp-desc">Professional services in Nairobi. Trusted by hundreds of customers across Kenya. Call us today for a free quote.</div>
            </div>
          </div>

          <!-- Result #2 -->
          <div class="serp-result serp-result--dim">
            <div class="serp-rank"><span class="rank-num rank-num--dim">2</span></div>
            <div class="serp-content">
              <div class="serp-url"><span class="serp-favicon">🌐</span><span>competitor-one.co.ke</span></div>
              <div class="serp-title serp-title--dim">Competitor One Ltd</div>
              <div class="serp-desc serp-desc--dim">Generic description. Slow loading website built on Wix. Page 1 by accident.</div>
            </div>
          </div>

          <!-- Result #3 -->
          <div class="serp-result serp-result--dim">
            <div class="serp-rank"><span class="rank-num rank-num--dim">3</span></div>
            <div class="serp-content">
              <div class="serp-url"><span class="serp-favicon">🌐</span><span>another-business.com</span></div>
              <div class="serp-title serp-title--dim">Another Business</div>
              <div class="serp-desc serp-desc--dim">We offer services. Contact us. Visit our website for more information about what we do.</div>
            </div>
          </div>

        </div>

        <!-- Floating badge 1 — bottom left -->
        <div class="float-badge-1">
          <div class="float-icon">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
            </svg>
          </div>
          <div class="float-text">
            <strong>50+ Websites</strong>
            <span>Delivered across Kenya</span>
          </div>
        </div>

        <!-- Floating badge 2 — top right -->
        <div class="float-badge-2">
          <span class="pulse-dot" aria-hidden="true"></span>
          <span>Delivered in 2 weeks</span>
        </div>

      </div>
    </div>

  </div>
</section>

<style>
  .hero {
    background: #ffffff;
    padding: 140px 0 100px;
    min-height: 100vh;
    display: flex;
    align-items: center;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
    width: 100%;
  }

  /* ── LEFT ── */
  .hero-left {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  /* Badge */
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #111111;
    color: #ffffff;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.04em;
    padding: 6px 14px;
    border-radius: 999px;
    margin-bottom: 28px;
    opacity: 0;
    transform: translateY(8px);
    animation: fadeUp 0.5s ease forwards 0.1s;
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    background: #e8590c;
    border-radius: 50%;
    flex-shrink: 0;
  }

  /* Headline */
  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(38px, 5.5vw, 64px);
    font-weight: 800;
    color: #111111;
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin-bottom: 0;
    opacity: 0;
    transform: translateY(12px);
    animation: fadeUp 0.55s ease forwards 0.2s;
  }

  .hero-title em {
    font-style: normal;
    color: #e8590c;
  }

  /* Subheadline */
  .hero-sub {
    font-size: 18px;
    color: #666666;
    line-height: 1.65;
    max-width: 460px;
    margin-top: 24px;
    opacity: 0;
    transform: translateY(12px);
    animation: fadeUp 0.55s ease forwards 0.32s;
  }

  /* Buttons */
  .hero-buttons {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 28px;
    opacity: 0;
    transform: translateY(12px);
    animation: fadeUp 0.55s ease forwards 0.56s;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 700;
    padding: 15px 28px;
    border-radius: 6px;
    text-decoration: none;
    border: 2px solid transparent;
    transition: background 0.2s ease, transform 0.2s ease,
                border-color 0.2s ease, color 0.2s ease;
    min-height: 50px;
  }

  .btn-primary {
    background: #2563eb;
    color: #ffffff;
    border-color: #2563eb;
  }

  .btn-primary:hover {
    background: #1d4ed8;
    border-color: #1d4ed8;
    transform: translateY(-2px);
  }

  .btn-secondary {
    background: #ffffff;
    color: #111111;
    border-color: #111111;
  }

  .btn-secondary:hover {
    background: #111111;
    color: #ffffff;
    transform: translateY(-2px);
  }

  /* Trust line */
  .hero-trust {
    font-family: 'Caveat', cursive;
    font-size: 22px;
    font-weight: 600;
    color: #888888;
    margin-top: 24px;
    margin-bottom: 0;
    opacity: 0;
    transform: translateY(8px);
    animation: fadeUp 0.5s ease forwards 0.44s;
  }

  .hero-trust::before {
    content: '← ';
    color: #e8590c;
  }

  /* ── RIGHT ── */
  .hero-right {
    opacity: 0;
    transform: translateX(16px);
    animation: fadeRight 0.6s ease forwards 0.3s;
  }

  .photo-wrap {
    position: relative;
    width: 100%;
  }

  /* ── SEO illustration ── */
  .seo-card {
    width: 100%;
    background: #ffffff;
    border: 1px solid #e5e5e5;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 24px rgba(0,0,0,0.08);
  }

  .serp-search {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 18px;
    border-bottom: 1px solid #e5e5e5;
    background: #fafafa;
  }

  .serp-g-logo {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  .serp-query {
    flex: 1;
    font-size: 14px;
    font-weight: 500;
    color: #111;
  }

  .serp-search-icon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  .serp-meta {
    font-size: 11px;
    color: #888;
    padding: 8px 18px;
    border-bottom: 1px solid #f0f0f0;
  }

  .serp-result {
    display: flex;
    gap: 12px;
    padding: 16px 18px;
    border-bottom: 1px solid #f0f0f0;
  }

  .serp-result:last-child {
    border-bottom: none;
  }

  .serp-rank {
    flex-shrink: 0;
    padding-top: 2px;
  }

  .rank-num {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    font-size: 11px;
    font-weight: 800;
    background: #2563eb;
    color: #fff;
  }

  .rank-num--dim {
    background: #e5e5e5;
    color: #888;
  }

  .serp-result--first {
    background: #f0f7ff;
    border-left: 3px solid #2563eb;
  }

  .serp-result--dim {
    opacity: 0.55;
  }

  .serp-content {
    flex: 1;
    min-width: 0;
  }

  .serp-url {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    color: #1a6b3c;
    margin-bottom: 3px;
  }

  .serp-favicon {
    font-size: 11px;
  }

  .serp-title {
    font-size: 14px;
    font-weight: 700;
    color: #1a0dab;
    margin-bottom: 4px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .serp-title--dim {
    color: #555;
  }

  .serp-desc {
    font-size: 12px;
    color: #444;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .serp-desc--dim {
    color: #888;
  }

  /* Floating badge 1 — bottom left */
  .float-badge-1 {
    position: absolute;
    bottom: -16px;
    left: -20px;
    background: #ffffff;
    border: 1px solid #e5e5e5;
    border-radius: 10px;
    padding: 14px 18px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.10);
    display: flex;
    align-items: center;
    gap: 12px;
    min-width: 200px;
    white-space: nowrap;
  }

  .float-icon {
    width: 36px;
    height: 36px;
    background: #e8590c;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .float-icon svg {
    width: 18px;
    height: 18px;
    fill: #ffffff;
  }

  .float-text strong {
    display: block;
    font-size: 15px;
    font-weight: 800;
    color: #111111;
    line-height: 1.2;
  }

  .float-text span {
    font-size: 12px;
    color: #888888;
  }

  /* Floating badge 2 — top right */
  .float-badge-2 {
    position: absolute;
    top: 24px;
    right: -20px;
    background: #111111;
    border-radius: 10px;
    padding: 12px 16px;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.20);
    display: flex;
    align-items: center;
    gap: 8px;
    white-space: nowrap;
  }

  .float-badge-2 span:last-child {
    font-size: 13px;
    font-weight: 700;
    color: #ffffff;
  }

  .pulse-dot {
    width: 8px;
    height: 8px;
    background: #22c55e;
    border-radius: 50%;
    flex-shrink: 0;
    animation: pulse 2s infinite;
  }

  /* ── Animations ── */
  @keyframes fadeUp {
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes fadeRight {
    to { opacity: 1; transform: translateX(0); }
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.6; transform: scale(1.3); }
  }

  /* ── MOBILE ── */
  @media (max-width: 768px) {
    .hero {
      padding: 104px 0 80px;
      min-height: auto;
      align-items: flex-start;
    }

    .hero-inner {
      grid-template-columns: 1fr;
      gap: 48px;
    }

    .hero-right {
      order: -1;
    }


    .hero-title {
      font-size: clamp(32px, 9vw, 40px);
    }

    .hero-sub {
      font-size: 16px;
      max-width: 100%;
    }

    .hero-buttons {
      flex-direction: column;
      width: 100%;
    }

    .btn {
      width: 100%;
      justify-content: center;
    }

    .float-badge-1 {
      bottom: -12px;
      left: 12px;
    }

    .float-badge-2 {
      top: 12px;
      right: 12px;
    }

    .hero-trust {
      font-size: 20px;
    }
  }

  @media (max-width: 375px) {
    .hero-title {
      font-size: 34px;
    }
  }
</style>
