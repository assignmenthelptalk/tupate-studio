---
import { SITE } from '../config';
---

<section class="hero">
  <div class="container hero-inner">

    <!-- LEFT -->
    <div class="hero-left">


      <h1 class="hero-title">
        Your competitors<br>are on Google.<br>
        We'll make sure you<br><em>outrank them.</em>
      </h1>

      <p class="hero-sub">
        Your customers are searching right now. Make sure they find you,
        not someone else.
      </p>

      <p class="hero-trust">A website built to get you customers, not an AI-made site that won't rank on Google.</p>

      <div class="hero-buttons">
        <a
          href={`https://wa.me/${SITE.whatsapp}?text=${encodeURIComponent(SITE.ctaWhatsappMessage)}`}
          class="btn btn-primary"
          target="_blank"
          rel="noopener"
        >
          Get a free quote →
        </a>
      </div>


    </div>

    <!-- RIGHT -->
    <div class="hero-right">
      <div class="photo-wrap">

        <!-- Two founders photo -->
        <img
          src="/founders.png"
          alt="Tupate Studio founders"
          class="hero-photo"
        />

      </div>
    </div>

  </div>
</section>

<style>
  .hero {
    background-color: #eef1fb;
    background-image:
      linear-gradient(135deg, #f5f7ff 0%, #e8eeff 60%, #dde4fc 100%);
    padding-top: 72px;
    height: 100vh;
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
    box-sizing: border-box;
  }

  /* Grid texture — top-right quadrant */
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(99, 120, 230, 0.10) 1px, transparent 1px),
      linear-gradient(90deg, rgba(99, 120, 230, 0.10) 1px, transparent 1px);
    background-size: 36px 36px;
    mask-image: radial-gradient(ellipse 70% 80% at 80% 30%, black 20%, transparent 75%);
    -webkit-mask-image: radial-gradient(ellipse 70% 80% at 80% 30%, black 20%, transparent 75%);
    pointer-events: none;
  }

  /* Decorative circle blob behind the carousel */
  .hero::after {
    content: '';
    position: absolute;
    right: -2%;
    top: 50%;
    transform: translateY(-50%);
    width: 52%;
    aspect-ratio: 1;
    border-radius: 50%;
    background: radial-gradient(circle, #c7d3f8 0%, #b8c8f5 40%, transparent 70%);
    opacity: 0.55;
    pointer-events: none;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: 48px;
    align-items: center;
    width: 100%;
    position: relative;
    z-index: 1;
  }

  /* ── LEFT ── */
  .hero-left {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  /* Badge */
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #ffffff;
    color: #1e2a6e;
    border: 1.5px solid #c5ceee;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.04em;
    padding: 6px 14px;
    border-radius: 999px;
    margin-bottom: 28px;
    box-shadow: 0 2px 8px rgba(99,120,230,0.10);
    opacity: 0;
    transform: translateY(8px);
    animation: fadeUp 0.5s ease forwards 0.1s;
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    background: #4361ee;
    border-radius: 50%;
    flex-shrink: 0;
  }

  /* Headline */
  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(38px, 5.5vw, 64px);
    font-weight: 800;
    color: #111111;
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin-bottom: 0;
    opacity: 0;
    transform: translateY(12px);
    animation: fadeUp 0.55s ease forwards 0.2s;
  }

  .hero-title em {
    font-style: normal;
    color: #e8590c;
  }

  /* Subheadline */
  .hero-sub {
    font-size: 18px;
    color: #666666;
    line-height: 1.65;
    max-width: 460px;
    margin-top: 24px;
    opacity: 0;
    transform: translateY(12px);
    animation: fadeUp 0.55s ease forwards 0.32s;
  }

  /* Buttons */
  .hero-buttons {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 28px;
    opacity: 0;
    transform: translateY(12px);
    animation: fadeUp 0.55s ease forwards 0.56s;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 700;
    padding: 15px 28px;
    border-radius: 6px;
    text-decoration: none;
    border: 2px solid transparent;
    transition: background 0.2s ease, transform 0.2s ease,
                border-color 0.2s ease, color 0.2s ease;
    min-height: 50px;
  }

  .btn-primary {
    background: #2563eb;
    color: #ffffff;
    border-color: #2563eb;
  }

  .btn-primary:hover {
    background: #1d4ed8;
    border-color: #1d4ed8;
    transform: translateY(-2px);
  }

  .btn-secondary {
    background: #ffffff;
    color: #111111;
    border-color: #111111;
  }

  .btn-secondary:hover {
    background: #111111;
    color: #ffffff;
    transform: translateY(-2px);
  }

  /* Trust line */
  .hero-trust {
    font-family: 'Caveat', cursive;
    font-size: 22px;
    font-weight: 600;
    color: #4361ee;
    margin-top: 24px;
    margin-bottom: 0;
    opacity: 0;
    transform: translateY(8px);
    animation: fadeUp 0.5s ease forwards 0.44s;
  }

  .hero-trust::before {
    content: '← ';
    color: #4361ee;
  }

  /* ── RIGHT ── */
  .hero-right {
    opacity: 0;
    transform: translateX(16px);
    animation: fadeRight 0.6s ease forwards 0.3s;
  }

  .photo-wrap {
    position: relative;
    width: 100%;
  }

  /* ── Hero photo ── */
  .hero-photo {
    width: 100%;
    max-height: 78vh;
    object-fit: cover;
    object-position: center top;
    border-radius: 16px;
    display: block;
  }


  /* ── Animations ── */
  @keyframes fadeUp {
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes fadeRight {
    to { opacity: 1; transform: translateX(0); }
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.6; transform: scale(1.3); }
  }

  /* ── MOBILE ── */
  @media (max-width: 768px) {
    .hero {
      height: auto;
      min-height: 100vh;
      padding: 100px 0 80px;
      align-items: flex-start;
    }

    .hero-inner {
      grid-template-columns: 1fr;
      gap: 48px;
    }

    .hero-right {
      order: -1;
    }


    .hero-title {
      font-size: clamp(32px, 9vw, 40px);
    }

    .hero-sub {
      font-size: 16px;
      max-width: 100%;
    }

    .hero-buttons {
      flex-direction: column;
      width: 100%;
    }

    .btn {
      width: 100%;
      justify-content: center;
    }

    .float-badge-1 {
      bottom: -12px;
      left: 12px;
    }

    .float-badge-2 {
      top: 12px;
      right: 12px;
    }

    .hero-trust {
      font-size: 20px;
    }
  }

  @media (max-width: 375px) {
    .hero-title {
      font-size: 34px;
    }
  }
</style>
