---
import { SITE } from '../config';
---

<section class="hero">
  <div class="container hero-inner">

    <!-- LEFT -->
    <div class="hero-left">

      <div class="hero-badge">KENYAN-OWNED &nbsp;·&nbsp; Serving businesses across Kenya &nbsp;→</div>

      <h1 class="hero-title">
        Your competitors are on Google.<br>
        We'll make sure you outrank them.
      </h1>

      <p class="hero-sub">
        Your customers are searching right now.
        Make sure they find you, not someone else.
      </p>

      <a
        href={`https://wa.me/${SITE.whatsapp}?text=${encodeURIComponent(SITE.ctaWhatsappMessage)}`}
        class="hero-cta"
        target="_blank"
        rel="noopener"
      >
        Get a free quote →
      </a>

      <p class="hero-trust">← No templates. No AI garbage. Just hand-coded sites that rank.</p>

    </div>

    <!-- RIGHT -->
    <div class="hero-right">
      <div class="photo-wrap">
        <div class="photo-placeholder">
          <span class="photo-label">Your photo here</span>
        </div>

        <div class="badge">
          <svg class="badge-icon" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <circle cx="10" cy="10" r="10" fill="#2563eb" fill-opacity="0.12"/>
            <path d="M5.5 10.5l3 3 6-6" stroke="#2563eb" stroke-width="1.8"
                  stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <div>
            <p class="badge-number">50+</p>
            <p class="badge-text">Websites Delivered</p>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .hero {
    background: #ffffff;
    padding: 140px 0 96px;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: 64px;
    align-items: center;
  }

  /* ── LEFT ── */
  .hero-badge {
    display: inline-flex;
    align-items: center;
    background: #111111;
    color: #ffffff;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 600;
    padding: 6px 16px;
    margin-bottom: 24px;
    letter-spacing: 0.02em;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(40px, 6vw, 64px);
    font-weight: 800;
    color: #111111;
    line-height: 1.05;
    letter-spacing: -0.02em;
  }

  .hero-sub {
    font-size: 18px;
    color: #666666;
    line-height: 1.6;
    max-width: 460px;
    margin-top: 20px;
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    background: #e8590c;
    color: #ffffff;
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 700;
    padding: 16px 32px;
    border-radius: 6px;
    margin-top: 32px;
    text-decoration: none;
    transition: background 0.2s ease, transform 0.2s ease;
  }

  .hero-cta:hover {
    background: #cf4e0a;
    transform: translateY(-2px);
  }

  .hero-trust {
    font-family: 'Caveat', cursive;
    font-size: 16px;
    font-weight: 600;
    color: #888888;
    display: inline-block;
    margin-top: 16px;
    margin-left: 12px;
  }

  /* ── RIGHT ── */
  .hero-right {
    display: flex;
    justify-content: center;
  }

  .photo-wrap {
    position: relative;
    width: 100%;
    max-width: 400px;
  }

  .photo-placeholder {
    width: 100%;
    aspect-ratio: 480 / 520;
    background: #f0f0f0;
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .photo-label {
    font-size: 14px;
    font-weight: 500;
    color: #aaaaaa;
    letter-spacing: 0.02em;
  }

  /* floating badge */
  .badge {
    position: absolute;
    bottom: -16px;
    left: -20px;
    background: #ffffff;
    border: 1px solid var(--border);
    border-radius: 12px;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.10);
    padding: 14px 18px;
    display: flex;
    align-items: center;
    gap: 12px;
    white-space: nowrap;
  }

  .badge-icon {
    width: 32px;
    height: 32px;
    flex-shrink: 0;
  }

  .badge-number {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 800;
    color: #111111;
    line-height: 1;
  }

  .badge-text {
    font-size: 12px;
    color: #666666;
    margin-top: 2px;
  }

  /* ── MOBILE ── */
  @media (max-width: 768px) {
    .hero {
      padding: 104px 0 72px;
    }

    .hero-inner {
      grid-template-columns: 1fr;
      gap: 48px;
    }

    .hero-title {
      font-size: clamp(32px, 9vw, 40px);
    }

    .hero-sub {
      font-size: 16px;
      max-width: 100%;
    }

    .hero-cta {
      font-size: 15px;
      padding: 14px 28px;
    }

    .hero-right {
      order: 2;
    }

    .photo-wrap {
      max-width: 100%;
    }

    .photo-placeholder {
      aspect-ratio: unset;
      height: 320px;
    }

    .badge {
      bottom: -14px;
      left: 16px;
    }

    .hero-trust {
      font-size: 15px;
      margin-left: 4px;
    }
  }
</style>
